/// Risposte dettagliate per questionari con scoring
/// Traccia ogni singola risposta per analisi e calcolo punteggio
model QuestionarioRisposta {
  id                   String             @id @default(uuid())
  documentoCompilatoId String             @map("documento_compilato_id")
  tenantId             String             @map("tenant_id")
  campoId              String             @map("campo_id")
  campoLabel           String?            @map("campo_label")
  valoreTesto          String?            @map("valore_testo")
  valoreNumerico       Float?             @map("valore_numerico")
  valoreBoolean        Boolean?           @map("valore_boolean")
  valoreData           DateTime?          @map("valore_data")
  valoreJson           Json?              @map("valore_json")
  punteggio            Float?
  pesoCalcolato        Float?             @map("peso_calcolato")
  flagCritico          Boolean            @default(false) @map("flag_critico")
  validato             Boolean            @default(false)
  validatoDa           String?            @map("validato_da")
  validatoAt           DateTime?          @map("validato_at")
  noteValidazione      String?            @map("note_validazione")
  createdAt            DateTime           @default(now()) @map("created_at")
