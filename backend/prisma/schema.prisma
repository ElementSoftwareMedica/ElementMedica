  googleTokens                                         GoogleTokens[]                 @relation("GoogleTokensUser")
  repartiResponsabile                                  Reparto[]                      @relation("RepartoResponsabile")
  sopralluogiEseguiti                                  Sopralluogo[]                  @relation("SopralluogoEsecutore")
