/// Associazione tra form templates (test) e corsi
/// Permette di assegnare test specifici per riskLevel e courseType
model CourseTestAssignment {
  id             String             @id @default(uuid())
  formTemplateId String
  courseId       String?
  riskLevel      RiskLevel?
  courseType     CourseType?
  testType       TestType           @default(INITIAL)
  isRequired     Boolean            @default(true)
  order          Int                @default(0)
  passingScore   Float?
  timeLimit      Int?
  isActive       Boolean            @default(true)
  tenantId       String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  course         Course?            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  formTemplate   FormTemplate       @relation(fields: [formTemplateId], references: [id], onDelete: Cascade)
  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  results        CourseTestResult[]

  @@unique([formTemplateId, courseId, riskLevel, courseType, testType, tenantId])
  @@index([tenantId])
  @@index([courseId])
  @@index([riskLevel])
  @@index([courseType])
  @@index([testType])
  @@index([formTemplateId])
  @@map("course_test_assignments")
}

/// Risultati dei test compilati dai partecipanti
model CourseTestResult {
  id                     String               @id @default(uuid())
  courseTestAssignmentId String
  scheduleId             String
  personId               String
  formSubmissionId       String?
