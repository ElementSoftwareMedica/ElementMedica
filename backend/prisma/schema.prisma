  compilabileDa         CompilatoreQuestionario @default(MEDICO) @map("compilabile_da")
  tempoStimato          Int?                    @map("tempo_stimato")
  istruzioniPaziente    String?                 @map("istruzioni_paziente")
  istruzioniMedico      String?                 @map("istruzioni_medico")
