  nominaRuolo             NominaRuolo?             @relation(fields: [nominaRuoloId], references: [id])
  person                  Person?                  @relation(fields: [personId], references: [id])
  preventivo              Preventivo?              @relation(fields: [preventivoId], references: [id])
  referto                 Referto?                 @relation(fields: [refertoId], references: [id])
  site                    CompanySite?             @relation(fields: [siteId], references: [id])
  sopralluogo             Sopralluogo?             @relation(fields: [sopralluogoId], references: [id])
  tariffarioMedico        TariffarioMedico?        @relation(fields: [tariffarioMedicoId], references: [id])
