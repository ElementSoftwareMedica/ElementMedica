/// Mansione interna (diversa da Mansione MDL per lavoratori clienti)
/// Definisce i ruoli interni del poliambulatorio
model MansioneInterna {
  id                    String           @id @default(uuid())
  tenantId              String
  nome                  String
  /// Sigla breve per calendario (es: FO, AM, ES)
  sigla                 String?          @db.VarChar(5)
  /// Colore esadecimale per UI
  colore                String?          @db.VarChar(7)
  descrizione           String?
  areaAziendale         AreaAziendale    @default(ALTRO)
  livelloGerarchico     Int              @default(1)
  requisitiMinimi       Json?
  competenzeRichieste   Json?
  responsabilita        Json?
  oreMinimeSettimanali  Decimal?         @db.Decimal(4, 1)
  oreMassimeSettimanali Decimal?         @db.Decimal(4, 1)
  /// Ruolo di default per chi ha questa mansione
  defaultRoleId         String?
  /// Override permessi specifici per questa mansione
  defaultPermissions    Json?
  isActive              Boolean          @default(true)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  deletedAt             DateTime?
  defaultRole           CustomRole?      @relation("MansioneInterna_DefaultRole", fields: [defaultRoleId], references: [id])
