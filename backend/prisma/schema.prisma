/// Rischi aggiuntivi per singolo lavoratore (NON condivisi con altri sulla stessa mansione)
/// Rischi personalizzati per singolo lavoratore.
/// Quando una mansione viene assegnata, i rischi della mansione vengono copiati qui.
/// Il lavoratore può poi aggiungere/rimuovere rischi individualmente senza influenzare altri lavoratori.
model LavoratoreRischioAggiuntivo {
  id                     String           @id @default(uuid())
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
  deletedAt              DateTime?
  personId               String
  tenantId               String
  codiceRischio          CodiceRischio
  livello                LivelloRischio   @default(MEDIO)
  categoria              CategoriaRischio
  descrizioneEsposizione String?
  fonteRischio           String?          @db.VarChar(200)
  periodicitaMesi        Int?
  note                   String?
  sourceMansioneId       String?          /// Se copiato da una mansione, traccia l'origine. Null = aggiunto manualmente.
  person                 Person           @relation("PersonRischiAggiuntivi", fields: [personId], references: [id], onDelete: Cascade)
  tenant                 Tenant           @relation(fields: [tenantId], references: [id])

  @@unique([personId, codiceRischio])
  @@index([tenantId])
  @@index([personId])
  @@index([deletedAt])
  @@index([sourceMansioneId])
  @@map("lavoratore_rischi_aggiuntivi")
}

