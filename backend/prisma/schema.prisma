  @@index([documentoCompilatoId])
  @@index([tenantId])
  @@index([campoId])
  @@map("questionari_risposte")
}

/// Scadenzario centralizzato
/// Aggrega tutte le tipologie di scadenze in un'unica tabella per gestione unificata,
/// dashboard centralizzata e sistema di alert automatici.
model DeadlineItem {
  id                String                @id @default(uuid())
  tenantId          String                @map("tenant_id")
  categoria         DeadlineCategory
  priorita          DeadlinePriority      @default(NORMAL)
  status            DeadlineStatus        @default(ATTIVA)
  entityType        String?               @map("entity_type")
  entityId          String?               @map("entity_id")
  dataScadenza      DateTime              @map("data_scadenza")
  dataPreavviso1    DateTime?             @map("data_preavviso_1")
  dataPreavviso2    DateTime?             @map("data_preavviso_2")
  responsabileId    String?               @map("responsabile_id")
  personId          String?               @map("person_id")
  companyProfileId  String?               @map("company_profile_id")
  siteId            String?               @map("site_id")
  titolo            String                @db.VarChar(255)
  descrizione       String?
  note              String?
  ubicazione        String?               @db.VarChar(255)
  quantita          Int?
  unitaMisura       String?               @map("unita_misura") @db.VarChar(50)
  lottoNumero       String?               @map("lotto_numero") @db.VarChar(100)
  farmacoId         String?               @map("farmaco_id")
  isRicorrente      Boolean               @default(false) @map("is_ricorrente")
  periodicitaMesi   Int?                  @map("periodicita_mesi")
  prossimaScadenza  DateTime?             @map("prossima_scadenza")
  notificaInviata1  Boolean               @default(false) @map("notifica_inviata_1")
  notificaInviata2  Boolean               @default(false) @map("notifica_inviata_2")
  notificaScadenza  Boolean               @default(false) @map("notifica_scadenza")
  completatoAt      DateTime?             @map("completato_at")
  completatoDa      String?               @map("completato_da")
  noteCompletamento String?               @map("note_completamento")
  createdAt         DateTime              @default(now()) @map("created_at")
  updatedAt         DateTime              @updatedAt @map("updated_at")
  deletedAt         DateTime?             @map("deleted_at")
  createdBy         String?               @map("created_by")
  companyProfile    CompanyTenantProfile? @relation(fields: [companyProfileId], references: [id])
  farmaco           Farmaco?              @relation(fields: [farmacoId], references: [id])
  person            Person?               @relation("PersonDeadline", fields: [personId], references: [id])
  responsabile      Person?               @relation("ResponsabileDeadline", fields: [responsabileId], references: [id])
  site              CompanySite?          @relation(fields: [siteId], references: [id])
  tenant            Tenant                @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([tenantId, categoria])
  @@index([tenantId, status])
  @@index([tenantId, dataScadenza])
  @@index([tenantId, status, dataScadenza])
  @@index([responsabileId])
  @@index([personId])
  @@index([companyProfileId])
  @@index([siteId])
  @@index([entityType, entityId])
  @@index([farmacoId])
  @@index([deletedAt])
  @@map("deadline_items")
}

/// Farmaco - Gestione farmaci e materiali sanitari con scadenza e ubicazione
/// Funzionalità richiesta: tracciare scadenza farmaci e dove si trovano
model Farmaco {
  id                  String             @id @default(uuid())
  tenantId            String             @map("tenant_id")
  codice              String             @db.VarChar(50)
  nome                String             @db.VarChar(255)
  principioAttivo     String?            @map("principio_attivo") @db.VarChar(255)
  formaFarmaceutica   FormaFarmaceutica? @map("forma_farmaceutica")
  dosaggio            String?            @db.VarChar(100)
  ubicazione          String             @db.VarChar(255)
  ambulatorioId       String?            @map("ambulatorio_id")
  quantitaDisponibile Int                @map("quantita_disponibile")
  unitaMisura         String             @default("pz") @map("unita_misura") @db.VarChar(50)
  quantitaMinima      Int?               @map("quantita_minima")
  dataScadenza        DateTime           @map("data_scadenza")
  lottoNumero         String?            @map("lotto_numero") @db.VarChar(100)
  fornitore           String?            @db.VarChar(255)
  dataAcquisto        DateTime?          @map("data_acquisto")
  prezzoAcquisto      Float?             @map("prezzo_acquisto")
  note                String?
  immagineUrl         String?            @map("immagine_url") @db.VarChar(500)
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")
  deletedAt           DateTime?          @map("deleted_at")
  createdBy           String?            @map("created_by")
  deadlines           DeadlineItem[]
  ambulatorio         Ambulatorio?       @relation(fields: [ambulatorioId], references: [id])
  tenant              Tenant             @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, codice])
  @@index([tenantId])
  @@index([tenantId, dataScadenza])
  @@index([tenantId, ubicazione])
  @@index([ambulatorioId])
  @@index([deletedAt])
  @@map("farmaci")
}

