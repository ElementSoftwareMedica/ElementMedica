generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Company {
  id                  String                    @id @default(uuid())
  piva                String?                   @unique @db.VarChar(11)
  codiceFiscale       String?                   @unique @db.VarChar(16)
  ragioneSociale      String                    @db.VarChar(255)
  formaGiuridica      String?                   @db.VarChar(50)
  sedeLegaleIndirizzo String?                   @db.VarChar(255)
  sedeLegaleCitta     String?                   @db.VarChar(100)
  sedeLegaleCap       String?                   @db.VarChar(10)
  sedeLegaleProvincia String?                   @db.VarChar(2)
  sedeLegaleNazione   String?                   @default("IT") @db.VarChar(2)
  codiceAteco         String?                   @db.VarChar(20)
  settore             String?                   @db.VarChar(100)
  dimensione          CompanySize?
  sdi                 String?                   @db.VarChar(7)
  pecFatturazione     String?                   @db.VarChar(255)
  createdAt           DateTime                  @default(now()) @db.Timestamp(6)
  updatedAt           DateTime                  @updatedAt @db.Timestamp(6)
  deletedAt           DateTime?                 @db.Timestamp(6)
  dataShareConsents   CompanyDataShareConsent[]
  tenantProfiles      CompanyTenantProfile[]

  @@index([piva])
  @@index([codiceFiscale])
  @@index([ragioneSociale])
  @@index([codiceAteco])
  @@index([deletedAt])
  @@map("companies")
}

model CompanyTenantProfile {
  id                         String                         @id @default(uuid())
  companyId                  String
  tenantId                   String
  referenteId                String?
  referenteRuolo             String?                        @db.VarChar(100)
  emailGenerale              String?                        @db.VarChar(255)
  telefonoGenerale           String?                        @db.VarChar(20)
  pec                        String?                        @db.VarChar(255)
  dataInizioRapporto         DateTime?                      @db.Date
  dataFineRapporto           DateTime?                      @db.Date
  tipoContratto              String?                        @db.VarChar(100)
  numeroContratto            String?                        @db.VarChar(50)
  valoreContrattoAnnuo       Decimal?                       @db.Decimal(12, 2)
  listinoPrezzi              String?                        @db.VarChar(50)
  scontoPercentuale          Decimal?                       @db.Decimal(5, 2)
  terminiPagamento           String?                        @db.VarChar(50)
  modalitaPagamento          String?                        @db.VarChar(50)
  iban                       String?                        @db.VarChar(34)
  noteCommerciali            String?
  noteOperative              String?
  noteInterne                String?
  status                     CompanyProfileStatus           @default(ACTIVE)
  isActive                   Boolean                        @default(true)
  isPrimary                  Boolean                        @default(false)
  dataShareConsent           Boolean                        @default(false)
  dataShareConsentDate       DateTime?                      @db.Timestamp(6)
  dataShareConsentBy         String?
  createdAt                  DateTime                       @default(now()) @db.Timestamp(6)
  updatedAt                  DateTime                       @updatedAt @db.Timestamp(6)
  deletedAt                  DateTime?                      @db.Timestamp(6)
  courseSchedules            CourseSchedule[]
  scheduleCompanies          ScheduleCompany[]
  templateLinks              TemplateLink[]
  allegati3B                 Allegato3B[]                   @relation("ProfileAllegati3B")
  appuntamentiMDL            Appuntamento[]                 @relation("AppuntamentiAzienda")
  codiciSconto               CodiceAzienda[]
  sites                      CompanySite[]
  company                    Company                        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  referente                  Person?                        @relation("CompanyReferente", fields: [referenteId], references: [id])
  tenant                     Tenant                         @relation("TenantCompanyProfiles", fields: [tenantId], references: [id], onDelete: Cascade)
  consulenzeMDL              ConsulenzaMDL[]
  convenzioni                ConvenzioneAzienda[]
  deadlines                  DeadlineItem[]
  fattureElettronicheCliente FatturaElettronica[]           @relation("FatturaElettronicaAzienda")
  fattureElettronicaTerzo    FatturaElettronica[]           @relation("FatturaElettronicaTerzoAzienda")
  movimentiContabili         MovimentoContabile[]
  nomine                     NominaRuolo[]                  @relation("ProfileNomine")
  domandeOT23                OT23[]                         @relation("ProfileOT23")
  malattieProfessionali      MalattiaProfessionale[]        @relation("ProfileMalattieProfessionali")
  personRoles                PersonRole[]
  personProfiles             PersonTenantProfile[]          @relation("ProfileCompanyTenant")
  statiOccupazionali         StatoOccupazionaleStorico[]     @relation("StoricoOccupazionaleCompanyProfile")
  preventivi                 Preventivo[]
  tariffariAssociations      TariffarioCompanyAssociation[]
  tenantAsSelfCompany        Tenant?                        @relation("TenantSelfCompany")

  @@unique([companyId, tenantId])
  @@index([companyId])
  @@index([tenantId])
  @@index([referenteId])
  @@index([status])
  @@index([tenantId, status])
  @@index([deletedAt])
  @@map("company_tenant_profiles")
}

model CompanyDataShareConsent {
  id              String                  @id @default(uuid())
  companyId       String
  sourceTenantId  String
  targetTenantId  String
  sharedDataTypes String[]
  excludedFields  String[]
  consentGiven    Boolean                 @default(false)
  consentDate     DateTime?               @db.Timestamp(6)
  consentGivenBy  String?                 @db.VarChar(100)
  consentMethod   ConsentMethod?
  consentProof    String?                 @db.VarChar(500)
  legalBasis      String?                 @db.VarChar(100)
  approvalStatus  DataShareApprovalStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?               @db.Timestamp(6)
  rejectedBy      String?
  rejectedAt      DateTime?               @db.Timestamp(6)
  rejectionReason String?                 @db.VarChar(500)
  requestedBy     String?
  requestedAt     DateTime?               @db.Timestamp(6)
  requestNotes    String?
  validFrom       DateTime                @default(now()) @db.Timestamp(6)
  validUntil      DateTime?               @db.Timestamp(6)
  isRevoked       Boolean                 @default(false)
  revokedAt       DateTime?               @db.Timestamp(6)
  revokedBy       String?
  revokedReason   String?                 @db.VarChar(500)
  lastAccessedAt  DateTime?               @db.Timestamp(6)
  accessCount     Int                     @default(0)
  createdAt       DateTime                @default(now()) @db.Timestamp(6)
  updatedAt       DateTime                @updatedAt @db.Timestamp(6)
  company         Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sourceTenant    Tenant                  @relation("SourceTenantCompanyConsent", fields: [sourceTenantId], references: [id], onDelete: Cascade)
  targetTenant    Tenant                  @relation("TargetTenantCompanyConsent", fields: [targetTenantId], references: [id], onDelete: Cascade)

  @@unique([companyId, sourceTenantId, targetTenantId])
  @@index([companyId])
  @@index([sourceTenantId])
  @@index([targetTenantId])
  @@index([isRevoked])
  @@index([validUntil])
  @@index([approvalStatus])
  @@map("company_data_share_consents")
}

model CompanySite {
  id                        String                @id @default(uuid())
  createdAt                 DateTime              @default(now()) @db.Timestamp(6)
  updatedAt                 DateTime              @updatedAt @db.Timestamp(6)
  deletedAt                 DateTime?             @db.Timestamp(6)
  companyTenantProfileId    String
  tenantId                  String
  siteName                  String                @db.VarChar(255)
  indirizzo                 String?               @db.VarChar(255)
  citta                     String?               @db.VarChar(100)
  cap                       String?               @db.VarChar(10)
  provincia                 String?               @db.VarChar(2)
  telefono                  String?               @db.VarChar(20)
  mail                      String?               @db.VarChar(255)
  personaRiferimento        String?               @db.VarChar(255)
  numeroPAT                 String?               @db.VarChar(20)
  referenteId               String?
  rsppId                    String?
  medicoCompetenteId        String?
  dvr                       String?               @db.VarChar(500)
  dvrDataAggiornamento      DateTime?             @db.Date
  ultimoSopralluogo         DateTime?             @db.Date
  prossimoSopralluogo       DateTime?             @db.Date
  valutazioneSopralluogo    String?               @db.VarChar(50)
  sopralluogoEseguitoDa     String?               @db.VarChar(200)
  ultimoSopralluogoRSPP     DateTime?             @db.Date
  prossimoSopralluogoRSPP   DateTime?             @db.Date
  noteSopralluogoRSPP       String?
  ultimoSopralluogoMedico   DateTime?             @db.Date
  prossimoSopralluogoMedico DateTime?             @db.Date
  noteSopralluogoMedico     String?
  dvrs                      DVR[]
  permissions               Permission[]
  reparti                   Reparto[]
  sopralluoghi              Sopralluogo[]
  advancedPermissions       AdvancedPermission[]
  companyTenantProfile      CompanyTenantProfile  @relation(fields: [companyTenantProfileId], references: [id], onDelete: Cascade)
  medicoCompetente          Person?               @relation("SiteMedicoCompetente", fields: [medicoCompetenteId], references: [id])
  referente                 Person?               @relation("SiteReferente", fields: [referenteId], references: [id])
  rspp                      Person?               @relation("SiteRSPP", fields: [rsppId], references: [id])
  tenant                    Tenant                @relation(fields: [tenantId], references: [id])
  consulenzeMDL             ConsulenzaMDL[]
  deadlines                 DeadlineItem[]
  mansioni                  Mansione[]            @relation("SiteMansioni")
  movimentiContabili        MovimentoContabile[]
  nomine                    NominaRuolo[]         @relation("SiteNomine")
  personProfiles            PersonTenantProfile[] @relation("ProfileSite")
  protocolliSanitari        ProtocolloSanitario[] @relation("SiteProtocolli")
  statiOccupazionali        StatoOccupazionaleStorico[] @relation("StoricoOccupazionaleSite")

  @@index([companyTenantProfileId])
  @@index([tenantId])
  @@index([referenteId])
  @@index([rsppId])
  @@index([medicoCompetenteId])
  @@index([deletedAt])
  @@map("company_sites")
}

model Course {
  id               String                 @id @default(uuid())
  title            String
  category         String?
  description      String?
  duration         String?
  certifications   String?
  code             String?
  contents         String?
  maxPeople        Int?
  pricePerPerson   Float?
  regulation       String?
  validityYears    Int?
  branchType       BranchType             @default(FORMAZIONE) @map("branch_type")
  tenantId         String
  status           CourseStatus?          @default(DRAFT)
  createdAt        DateTime               @default(now())
  deletedAt        DateTime?
  updatedAt        DateTime               @default(now()) @updatedAt
  courseType       CourseType?
  fullDescription  String?
  image1Url        String?
  image2Url        String?
  isPublic         Boolean                @default(false)
  riskLevel        RiskLevel?
  seoDescription   String?
  seoTitle         String?
  shortDescription String?
  slug             String?
  subcategory      String?
  practicalHours   Int?
  seoId            String?
  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schedules        CourseSchedule[]
  codiciSconto     CodiceCorso[]
  testAssignments  CourseTestAssignment[]

  @@unique([tenantId, code])
  @@unique([tenantId, slug])
  @@unique([tenantId, seoId])
  @@index([tenantId])
  @@index([tenantId, branchType])
  @@index([tenantId, status])
  @@index([status, createdAt])
  @@index([isPublic])
  @@index([slug])
  @@index([riskLevel])
  @@index([courseType])
  @@index([category, riskLevel])
  @@index([isPublic, status])
}

model CourseSchedule {
  id                     String                   @id @default(uuid())
  courseId               String
  location               String?
  companyTenantProfileId String?
  notes                  String?
  trainerId              String?
  attendance             Json?
  hasAttestati           Boolean                  @default(false)
  deliveryMode           DeliveryMode?
  endDate                DateTime
  maxParticipants        Int?
  startDate              DateTime
  status                 EnrollmentStatus?        @default(PREVENTIVO)
  expiryDate             DateTime?
  createdAt              DateTime                 @default(now())
  deletedAt              DateTime?
  branchType             BranchType               @default(FORMAZIONE) @map("branch_type")
  tenantId               String
  updatedAt              DateTime                 @updatedAt
  isPublic               Boolean?                 @default(false)
  source                 ScheduleSource?          @default(INTERNAL)
  externalCompletedDate  DateTime?
  importedBy             String?
  importedAt             DateTime?
  importNotes            String?
  companyTenantProfile   CompanyTenantProfile?    @relation(fields: [companyTenantProfileId], references: [id])
  course                 Course                   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tenant                 Tenant                   @relation(fields: [tenantId], references: [id])
  trainer                Person?                  @relation("ScheduleTrainer", fields: [trainerId], references: [id])
  sessions               CourseSession[]
  companies              ScheduleCompany[]
  attestati              Attestato[]
  contact_submissions    ContactSubmission[]
  enrollments            CourseEnrollment[]
  testResults            CourseTestResult[]
  lettereIncarico        LetteraIncarico[]
  movimentiContabili     MovimentoContabile[]
  preventivi             Preventivo[]
  publicEnrollments      PublicCourseEnrollment[] @relation("PublicEnrollmentSchedule")
  registriPresenze       RegistroPresenze[]

  @@index([companyTenantProfileId])
  @@index([courseId])
  @@index([trainerId])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
  @@index([startDate, endDate])
  @@index([companyTenantProfileId, startDate])
  @@index([tenantId])
  @@index([tenantId, branchType])
  @@index([tenantId, status])
}

model CourseEnrollment {
  id         String            @id @default(uuid())
  scheduleId String
  personId   String            @map("employee_id")
  status     EnrollmentStatus? @default(PREVENTIVO)
  createdAt  DateTime          @default(now())
  deletedAt  DateTime?
  tenantId   String
  updatedAt  DateTime          @updatedAt
  person     Person            @relation("CourseEnrollment_Person", fields: [personId], references: [id], onDelete: Cascade)
  schedule   CourseSchedule    @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([scheduleId, personId])
  @@index([tenantId])
  @@index([personId])
  @@index([scheduleId])
  @@index([personId, status])
  @@index([scheduleId, status])
  @@map("course_enrollments")
}

model CourseSession {
  id               String             @id @default(uuid())
  scheduleId       String
  date             DateTime
  start            String
  end              String
  trainerId        String?
  coTrainerId      String?
  deletedAt        DateTime?
  tenantId         String
  coTrainer        Person?            @relation("SessionCoTrainer", fields: [coTrainerId], references: [id], onDelete: Cascade)
  schedule         CourseSchedule     @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trainer          Person?            @relation("SessionTrainer", fields: [trainerId], references: [id], onDelete: Cascade)
  registroPresenze RegistroPresenze[]

  @@index([tenantId])
  @@index([coTrainerId])
  @@index([scheduleId])
  @@index([trainerId])
}

model ScheduleCompany {
  id                     String               @id @default(uuid())
  scheduleId             String
  companyTenantProfileId String
  deletedAt              DateTime?
  tenantId               String
  companyTenantProfile   CompanyTenantProfile @relation(fields: [companyTenantProfileId], references: [id], onDelete: Cascade)
  schedule               CourseSchedule       @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  tenant                 Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([companyTenantProfileId])
  @@index([scheduleId])
}

model Attestato {
  id                  String         @id @default(uuid())
  personId            String         @map("partecipante_id")
  fileName            String         @map("nome_file")
  fileUrl             String         @map("url")
  generatedAt         DateTime       @default(now()) @map("data_generazione")
  annoProgressivo     Int
  numeroProgressivo   Int
  scheduledCourseId   String
  createdAt           DateTime       @default(now())
  deletedAt           DateTime?
  tenantId            String
  updatedAt           DateTime       @updatedAt
  fileSize            Int?
  generatedBy         String?
  markers             Json?
  templateId          String?
  templateVersion     Int?
  firmaFormatore      String?        @map("firma_formatore")
  firmaFormatoreAt    DateTime?      @map("firma_formatore_at")
  firmaFormatoreId    String?        @map("firma_formatore_id")
  firmaPartecipante   String?        @map("firma_partecipante")
  firmaPartecipanteAt DateTime?      @map("firma_partecipante_at")
  formatoreFirmante   Person?        @relation("AttestatiFormatoreSignature", fields: [firmaFormatoreId], references: [id])
  person              Person         @relation("Attestato_Person", fields: [personId], references: [id], onDelete: Cascade)
  scheduledCourse     CourseSchedule @relation(fields: [scheduledCourseId], references: [id], onDelete: Cascade)
  template            TemplateLink?  @relation(fields: [templateId], references: [id])
  tenant              Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([personId])
  @@index([scheduledCourseId])
  @@index([templateId])
  @@map("attestati")
}

model TemplateLink {
  id                     String                @id @default(uuid())
  name                   String
  url                    String
  content                String?
  footer                 String?
  header                 String?
  isDefault              Boolean               @default(false)
  logoPosition           String?
  googleDocsUrl          String?
  logoImage              String?
  companyTenantProfileId String?
  createdAt              DateTime              @default(now())
  deletedAt              DateTime?
  tenantId               String
  updatedAt              DateTime              @updatedAt
  category               String?
  createdBy              String?
  description            String?
  isActive               Boolean               @default(true)
  lastSyncedAt           DateTime?
  layout                 Json?
  markerSchema           Json?
  markers                Json?
  styles                 Json?
  syncEnabled            Boolean               @default(false)
  tags                   String[]              @default([])
  version                Int                   @default(1)
  type                   TemplateType
  fileFormat             TemplateFormat        @default(HTML)
  autoSync               Boolean               @default(false)
  googleDocsId           String?
  googleSlidesId         String?
  generatedDocs          GeneratedDocument[]
  companyTenantProfile   CompanyTenantProfile? @relation(fields: [companyTenantProfileId], references: [id])
  creator                Person?               @relation("TemplateCreator", fields: [createdBy], references: [id])
  tenant                 Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  versions               TemplateVersion[]
  attestati              Attestato[]
  lettereIncarico        LetteraIncarico[]
  registriPresenze       RegistroPresenze[]

  @@index([tenantId])
  @@index([companyTenantProfileId])
  @@index([tenantId, type])
  @@index([tenantId, type, isActive])
  @@index([isDefault, type])
  @@index([deletedAt])
  @@index([createdBy])
}

model TemplateVersion {
  id             String       @id @default(uuid())
  templateId     String
  version        Int
  content        String
  header         String?
  footer         String?
  styles         Json?
  layout         Json?
  markers        Json?
  changesSummary String?
  changeDetails  Json?
  createdBy      String
  createdAt      DateTime     @default(now())
  tenantId       String
  creator        Person       @relation("VersionCreator", fields: [createdBy], references: [id])
  template       TemplateLink @relation(fields: [templateId], references: [id], onDelete: Cascade)
  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@index([templateId, createdAt])
  @@index([tenantId])
}

model GeneratedDocument {
  id              String         @id @default(uuid())
  templateId      String
  templateVersion Int
  type            TemplateType
  entityType      String
  entityId        String
  filename        String
  filepath        String
  fileUrl         String
  fileSize        Int
  fileHash        String?
  mimeType        String         @default("application/pdf")
  markers         Json
  metadata        Json?
  status          DocumentStatus @default(GENERATED)
  batchId         String?
  batchSize       Int?
  batchIndex      Int?
  sentAt          DateTime?
  sentTo          String?
  downloadCount   Int            @default(0)
  lastDownloadAt  DateTime?
  signedAt        DateTime?
  signedBy        String?
  signedFilepath  String?
  generatedBy     String
  generatedAt     DateTime       @default(now())
  tenantId        String
  deletedAt       DateTime?
  generator       Person         @relation("DocumentGenerator", fields: [generatedBy], references: [id])
  template        TemplateLink   @relation(fields: [templateId], references: [id])
  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@index([entityType, entityId])
  @@index([tenantId, generatedAt])
  @@index([generatedBy])
  @@index([batchId])
  @@index([status])
  @@index([type, status])
}

model GoogleTokens {
  id           String   @id @default(uuid())
  userId       String
  tenantId     String
  accessToken  String
  refreshToken String?
  expiryDate   BigInt
  scope        String[] @default([])
  tokenType    String   @default("Bearer")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         Person   @relation("GoogleTokensUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([userId])
  @@index([tenantId])
  @@index([expiryDate])
}

model LetteraIncarico {
  id                  String         @id @default(uuid())
  scheduledCourseId   String
  trainerId           String
  nomeFile            String
  url                 String
  dataGenerazione     DateTime       @default(now())
  numeroProgressivo   Int
  annoProgressivo     Int
  createdAt           DateTime       @default(now())
  deletedAt           DateTime?
  tenantId            String
  updatedAt           DateTime       @updatedAt
  fileSize            Int?
  generatedBy         String?
  markers             Json?
  templateId          String?
  templateVersion     Int?
  firmaFormatore      String?        @map("firma_formatore")
  firmaFormatoreAt    DateTime?      @map("firma_formatore_at")
  firmaDatoreLavoro   String?        @map("firma_datore_lavoro")
  firmaDatoreLavoroAt DateTime?      @map("firma_datore_lavoro_at")
  firmaDatoreLavoroId String?        @map("firma_datore_lavoro_id")
  datoreFirmante      Person?        @relation("LettereIncaricoSignature", fields: [firmaDatoreLavoroId], references: [id])
  scheduledCourse     CourseSchedule @relation(fields: [scheduledCourseId], references: [id], onDelete: Cascade)
  template            TemplateLink?  @relation(fields: [templateId], references: [id])
  tenant              Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  trainer             Person         @relation("LetteraIncaricoTrainer", fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([scheduledCourseId, trainerId])
  @@index([templateId])
  @@index([tenantId])
  @@index([scheduledCourseId])
  @@index([trainerId])
  @@map("lettere_incarico")
}

model RegistroPresenze {
  id                  String                         @id @default(uuid())
  scheduledCourseId   String
  sessionId           String
  nomeFile            String
  url                 String
  dataGenerazione     DateTime                       @default(now())
  numeroProgressivo   Int
  annoProgressivo     Int
  formatoreId         String
  createdAt           DateTime                       @default(now())
  deletedAt           DateTime?
  tenantId            String
  updatedAt           DateTime                       @updatedAt
  fileSize            Int?
  generatedBy         String?
  markers             Json?
  templateId          String?
  templateVersion     Int?
  firmaFormatore      String?
  firmaFormatoreAt    DateTime?
  firmaFormatoreId    String?
  firmaFormatoreIp    String?                        @db.VarChar(45)
  formatoreFirmatario Person?                        @relation("RegistroFirmaFormatore", fields: [firmaFormatoreId], references: [id])
  formatore           Person                         @relation("RegistroFormatore", fields: [formatoreId], references: [id], onDelete: Cascade)
  scheduledCourse     CourseSchedule                 @relation(fields: [scheduledCourseId], references: [id], onDelete: Cascade)
  session             CourseSession                  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  template            TemplateLink?                  @relation(fields: [templateId], references: [id])
  tenant              Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  presenti            RegistroPresenzePartecipante[]

  @@index([tenantId])
  @@index([formatoreId])
  @@index([scheduledCourseId])
  @@index([sessionId])
  @@index([templateId])
  @@index([firmaFormatoreId])
  @@map("registri_presenze")
}

model RegistroPresenzePartecipante {
  id                 String           @id @default(uuid())
  personId           String           @map("partecipante_id")
  presente           Boolean          @default(false)
  ore                Float?           @map("hours")
  note               String?
  registroPresenzeId String
  createdAt          DateTime         @default(now())
  deletedAt          DateTime?
  tenantId           String
  updatedAt          DateTime         @updatedAt
