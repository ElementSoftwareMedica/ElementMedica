  recipient              Person?                  @relation("ReceivedNotifications", fields: [recipientId], references: [id])
  rule                   NotificationRule?        @relation(fields: [ruleId], references: [id])
  tenant                 Tenant                   @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([recipientId])
  @@index([groupId])
  @@index([type])
  @@index([category])
  @@index([priority])
  @@index([scheduledAt])
  @@index([createdAt])
  @@index([tenantId, recipientId, createdAt])
  @@index([tenantId, type, priority, createdAt])
  @@index([tenantId, category, createdAt])
  @@index([scheduledAt, deletedAt])
  @@map("notifications")
}

