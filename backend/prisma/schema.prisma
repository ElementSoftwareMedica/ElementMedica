  testPartecipanti                                     TestPartecipante[]             @relation("TestPartecipante_Person")
  createdTemplates                                     TemplateLink[]                 @relation("TemplateCreator")
  createdVersions                                      TemplateVersion[]              @relation("VersionCreator")
  generatedDocuments                                   GeneratedDocument[]            @relation("DocumentGenerator")
  googleTokens                                         GoogleTokens[]                 @relation("GoogleTokensUser")
  codiciSconto                                         CodicePersona[]                @relation("CodicePersona_Person")
  preventivi                                           Preventivo[]                   @relation("PreventivoPersonaDiretta")

  // Clinical Relations (ElementMedica)
  poliambulatoriDiretti                                Poliambulatorio[]              @relation("DirettoreSanitario")
  appuntamentiPaziente                                 Appuntamento[]                 @relation("AppuntamentiPaziente")
  appuntamentiMedico                                   Appuntamento[]                 @relation("AppuntamentiMedico")
  visitePaziente                                       Visita[]                       @relation("VisitePaziente")
  visiteMedico                                         Visita[]                       @relation("VisiteMedico")
  disponibilita                                        DisponibilitaMedico[]          @relation("DisponibilitaMedico")
  ferieAssenze                                         FerieAssenza[]                 @relation("FerieAssenzaMedico")
  fattureSanitarie                                     FatturaSanitaria[]             @relation("FattureSanitariePaziente")
  firmeDigitali                                        FirmaDigitale[]                @relation("FirmeDigitali")
  slotsDisponibilita                                   SlotDisponibilita[]            @relation("SlotsDisponibilita")
  auditLogsClinici                                     AuditLogClinico[]              @relation("AuditLogsClinici")

