}

model ActivityLog {
  id         String      @id @default(uuid())
  personId   String      @map("user_id")
  action     String // Azione eseguita (enum ActivityType)
  category   String? // Categoria (AUTH, CRUD, NAVIGATION, etc.)
  resource   String? // Risorsa coinvolta (Company, Course, etc.)
  resourceId String? // ID della risorsa
  details    String? // Dettagli aggiuntivi (legacy, JSON string)
  metadata   Json? // Metadata strutturato (nuovo)
  ipAddress  String? // IP address
  userAgent  String?     @db.VarChar(500) // Browser/device info
  sessionId  String? // Link a PersonSession
  duration   Int? // Durata operazione (ms)
  success    Boolean     @default(true) // Successo/fallimento
  errorCode  String? // Codice errore se fallito
  branchType BranchType? @map("branch_type") // Progetto 45: branch in cui è avvenuta l'azione (null = cross-branch)
  timestamp  DateTime    @default(now())
  createdAt  DateTime    @default(now())
  deletedAt  DateTime?
  updatedAt  DateTime    @updatedAt
  tenantId   String

  // Relations
  tenant  Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  person  Person         @relation("ActivityLog_Person", fields: [personId], references: [id], onDelete: Cascade)
  session PersonSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  // Indexes for performance
  @@index([tenantId])
  @@index([tenantId, branchType]) // Progetto 45
  @@index([personId])
  @@index([personId, timestamp])
  @@index([action, timestamp])
  @@index([category, timestamp])
  @@index([resource, resourceId])
  @@index([sessionId])
  @@index([timestamp])
  @@index([tenantId, deletedAt])
  @@map("activity_logs")
}

