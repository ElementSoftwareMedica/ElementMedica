// ===========================================
// TARIFFARIO AZIENDE - MEDICINA DEL LAVORO
// ===========================================

// Tariffario Aziendale - gestisce sia template base che tariffari specifici per azienda
model TariffarioAziendale {
  id                  String              @id @default(uuid())
  codice              String
  nome                String
  descrizione         String?
  
  // Tipologia: BASE = template, AZIENDALE = specifico per company
  tipo                TipoTariffario      @default(BASE)
  
  // Company (obbligatorio solo per tipo AZIENDALE)
  companyId           String?
  company             Company?            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  // Tariffario origine (se questo è derivato/clonato da un base)
  tariffarioOrigineId String?
  tariffarioOrigine   TariffarioAziendale?  @relation("TariffarioDerivato", fields: [tariffarioOrigineId], references: [id], onDelete: SetNull)
  tariffariDerivati   TariffarioAziendale[] @relation("TariffarioDerivato")
  
  // Convenzione associata (opzionale)
  convenzioneId       String?
  convenzione         Convenzione?        @relation(fields: [convenzioneId], references: [id], onDelete: SetNull)
  
  // Validità temporale
  validoDa            DateTime            @default(now())
  validoA             DateTime?
  attivo              Boolean             @default(true)
  
  // Successore programmato (per tariffari che scadono e hanno un successore)
  successoreId        String?             @unique
  successore          TariffarioAziendale?  @relation("TariffarioSuccessore", fields: [successoreId], references: [id], onDelete: SetNull)
  predecessore        TariffarioAziendale?  @relation("TariffarioSuccessore")
  
  // Voci del tariffario
  voci                VoceTariffario[]
  
  // Note e metadati
  note                String?
  tenantId            String
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  deletedAt           DateTime?
  createdBy           String?

  @@unique([tenantId, codice])
  @@index([tenantId])
  @@index([tipo])
  @@index([companyId])
  @@index([convenzioneId])
  @@index([attivo])
  @@index([tenantId, tipo, attivo])
  @@index([tenantId, companyId, attivo])
  @@map("tariffari_aziendali")
}

// Voce singola del tariffario - può essere prestazione o spesa fissa/ricorrente
model VoceTariffario {
  id                    String              @id @default(uuid())
  tariffarioAziendaleId String
  tariffarioAziendale   TariffarioAziendale @relation(fields: [tariffarioAziendaleId], references: [id], onDelete: Cascade)
  
  // Tipo voce
  tipo                  TipoVoceTariffario
  
  // Se tipo = PRESTAZIONE: collegamento a Prestazione esistente
  prestazioneId         String?
  prestazione           Prestazione?        @relation(fields: [prestazioneId], references: [id], onDelete: SetNull)
  
  // Se tipo = SPESA_FISSA o SPESA_RICORRENTE: nome e descrizione custom
  nome                  String?             // Nome spesa (obbligatorio se non prestazione)
  descrizione           String?
  
  // Pricing
  prezzoBase            Decimal             @db.Decimal(10, 2)
  ivaAliquota           Decimal             @default(22) @db.Decimal(5, 2)
  
  // Frequenza di applicazione
  frequenza             FrequenzaTariffario @default(UNA_TANTUM)
  
  // Fasce dipendenti - se true, usa le fasce invece del prezzoBase
  usaFasceDipendenti    Boolean             @default(false)
  fasceDipendenti       FasciaDipendentiPrezzo[]
  
  // Ordinamento e stato
  ordine                Int                 @default(0)
  attivo                Boolean             @default(true)
  note                  String?
  
  // Metadata
  tenantId              String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?

  @@index([tariffarioAziendaleId])
  @@index([tenantId])
  @@index([tipo])
  @@index([prestazioneId])
  @@index([tenantId, attivo])
  @@map("voci_tariffario")
}

// Fasce prezzo basate sul numero di dipendenti dell'azienda
model FasciaDipendentiPrezzo {
  id                String          @id @default(uuid())
  voceTariffarioId  String
  voceTariffario    VoceTariffario  @relation(fields: [voceTariffarioId], references: [id], onDelete: Cascade)
  
  // Range dipendenti
  minDipendenti     Int             // es. 0, 5, 11
  maxDipendenti     Int?            // null = illimitato (es. 11+)
  
  // Prezzo per questa fascia
  prezzo            Decimal         @db.Decimal(10, 2)
  
  // Descrizione fascia (opzionale, es. "Micro impresa", "PMI")
  descrizione       String?
  
  tenantId          String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  deletedAt         DateTime?

  @@index([voceTariffarioId])
  @@index([tenantId])
  @@map("fasce_dipendenti_prezzo")
}
