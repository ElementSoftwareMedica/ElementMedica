/// Notifica principale del sistema - Progetto 47
model Notification {
  id                     String                   @id @default(uuid())
  tenantId               String
  recipientId            String?
  groupId                String?
  title                  String
  body                   String
  shortBody              String?
  type                   NotificationType         @default(INFO)
  category               NotificationCategory     @default(SYSTEM)
  priority               NotificationPriority     @default(NORMAL)
  icon                   String?
  iconColor              String?
  bgColor                String?
  isDismissable          Boolean                  @default(true)
  requiresConfirmation   Boolean                  @default(false)
  forcePopup             Boolean                  @default(false)
  forcedOrder            Int?
  channels               NotificationChannel[]    @default([IN_APP])
  scheduledAt            DateTime?
  expiresAt              DateTime?
  entityType             String?
  entityId               String?
  actionUrl              String?
  actionLabel            String?
  triggeredBy            String?
  ruleId                 String?
