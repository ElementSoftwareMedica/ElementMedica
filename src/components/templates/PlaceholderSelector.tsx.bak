/**
 * Placeholder Selector Component
 * Organizes and displays available placeholders by entity type
 */

import React, { useState } from 'react';
import { Search, Copy, Check, ChevronDown, ChevronRight } from 'lucide-react';

interface Placeholder {
  key: string;
  label: string;
  description: string;
  example?: string;
}

interface PlaceholderCategory {
  name: string;
  icon: string;
  placeholders: Placeholder[];
}

// Organized placeholder data by entity
const PLACEHOLDER_CATEGORIES: PlaceholderCategory[] = [
  {
    name: 'Formatore',
    icon: '👤',
    placeholders: [
      { key: 'NOME_FORMATORE', label: 'Nome', description: 'Nome del formatore', example: 'Mario' },
      { key: 'COGNOME_FORMATORE', label: 'Cognome', description: 'Cognome del formatore', example: 'Rossi' },
      { key: 'NOME_COMPLETO_FORMATORE', label: 'Nome Completo', description: 'Nome e cognome', example: 'Mario Rossi' },
      { key: 'EMAIL_FORMATORE', label: 'Email', description: 'Email del formatore', example: 'mario.rossi@example.com' },
      { key: 'TELEFONO_FORMATORE', label: 'Telefono', description: 'Numero di telefono', example: '+39 123 456 7890' },
      { key: 'CF_FORMATORE', label: 'Codice Fiscale', description: 'Codice fiscale del formatore', example: 'RSSMRA80A01H501Z' },
      { key: 'PIVA_FORMATORE', label: 'Partita IVA', description: 'Partita IVA del formatore', example: '12345678901' },
    ]
  },
  {
    name: 'Corso',
    icon: '📚',
    placeholders: [
      { key: 'CORSO_TITOLO', label: 'Titolo', description: 'Titolo del corso', example: 'Sicurezza sul Lavoro' },
      { key: 'CORSO_DESCRIZIONE', label: 'Descrizione', description: 'Descrizione dettagliata', example: 'Corso base...' },
      { key: 'CORSO_CODICE', label: 'Codice', description: 'Codice identificativo', example: 'SIC-001' },
      { key: 'CORSO_DURATA', label: 'Durata', description: 'Durata in ore', example: '40' },
      { key: 'ORE_TOTALI', label: 'Ore Totali', description: 'Ore totali del corso', example: '40' },
      { key: 'PRIMA_DATA', label: 'Data Inizio', description: 'Prima data sessione', example: '01/12/2025' },
      { key: 'ULTIMA_DATA', label: 'Data Fine', description: 'Ultima data sessione', example: '15/12/2025' },
      { key: 'LUOGO_CORSO', label: 'Luogo', description: 'Luogo di svolgimento', example: 'Milano' },
    ]
  },
  {
    name: 'Azienda',
    icon: '🏢',
    placeholders: [
      { key: 'AZIENDA_RAGIONE_SOCIALE', label: 'Ragione Sociale', description: 'Nome azienda', example: 'Acme S.r.l.' },
      { key: 'AZIENDA_INDIRIZZO', label: 'Indirizzo', description: 'Indirizzo completo', example: 'Via Roma 1, Milano' },
      { key: 'AZIENDA_PIVA', label: 'Partita IVA', description: 'P.IVA azienda', example: '12345678901' },
      { key: 'AZIENDA_CF', label: 'Codice Fiscale', description: 'CF azienda', example: '12345678901' },
      { key: 'AZIENDA_EMAIL', label: 'Email', description: 'Email aziendale', example: 'info@acme.it' },
      { key: 'AZIENDA_TELEFONO', label: 'Telefono', description: 'Telefono aziendale', example: '+39 02 1234567' },
      { key: 'AZIENDA_PEC', label: 'PEC', description: 'Posta certificata', example: 'acme@pec.it' },
    ]
  },
  {
    name: 'Partecipante',
    icon: '👥',
    placeholders: [
      { key: 'NOME_PARTECIPANTE', label: 'Nome', description: 'Nome del partecipante', example: 'Luigi' },
      { key: 'COGNOME_PARTECIPANTE', label: 'Cognome', description: 'Cognome del partecipante', example: 'Verdi' },
      { key: 'NOME_COMPLETO_PARTECIPANTE', label: 'Nome Completo', description: 'Nome e cognome', example: 'Luigi Verdi' },
      { key: 'CF_PARTECIPANTE', label: 'Codice Fiscale', description: 'CF partecipante', example: 'VRDLGU85M01H501K' },
      { key: 'DATA_NASCITA_PARTECIPANTE', label: 'Data Nascita', description: 'Data di nascita', example: '01/08/1985' },
      { key: 'LUOGO_NASCITA_PARTECIPANTE', label: 'Luogo Nascita', description: 'Luogo di nascita', example: 'Roma' },
    ]
  },
  {
    name: 'Compenso',
    icon: '💰',
    placeholders: [
      { key: 'TARIFFA_ORARIA', label: 'Tariffa Oraria', description: 'Compenso orario', example: '50,00 €' },
      { key: 'COMPENSO_TOTALE', label: 'Compenso Totale', description: 'Compenso totale', example: '2.000,00 €' },
      { key: 'NUMERO_ORE', label: 'Numero Ore', description: 'Ore erogate', example: '40' },
      { key: 'ALIQUOTA_IVA', label: 'Aliquota IVA', description: 'Percentuale IVA', example: '22%' },
      { key: 'IMPORTO_IVA', label: 'Importo IVA', description: 'IVA calcolata', example: '440,00 €' },
      { key: 'TOTALE_LORDO', label: 'Totale Lordo', description: 'Totale con IVA', example: '2.440,00 €' },
    ]
  },
  {
    name: 'Documento',
    icon: '📄',
    placeholders: [
      { key: 'DATA_GENERAZIONE', label: 'Data Generazione', description: 'Data creazione documento', example: '06/11/2025' },
      { key: 'NUMERO_PROGRESSIVO', label: 'Numero Progressivo', description: 'Numero documento', example: '0001/2025' },
      { key: 'ANNO_CORRENTE', label: 'Anno', description: 'Anno corrente', example: '2025' },
      { key: 'DATA_SCADENZA', label: 'Data Scadenza', description: 'Data di scadenza', example: '06/11/2030' },
      { key: 'NUMERO_PROTOCOLLO', label: 'Protocollo', description: 'Numero protocollo', example: 'PROT-2025-001' },
    ]
  },
  {
    name: 'Sistema',
    icon: '⚙️',
    placeholders: [
      { key: 'NOME_PIATTAFORMA', label: 'Nome Piattaforma', description: 'Nome del sistema', example: 'ElementMedica' },
      { key: 'URL_PIATTAFORMA', label: 'URL Piattaforma', description: 'URL del sistema', example: 'https://app.elementmedica.it' },
      { key: 'LOGO_PIATTAFORMA', label: 'Logo', description: 'Logo del sistema', example: '[Logo]' },
    ]
  },
];

interface PlaceholderSelectorProps {
  onSelect: (placeholder: string) => void;
  selectedPlaceholders?: string[];
}

export const PlaceholderSelector: React.FC<PlaceholderSelectorProps> = ({
  onSelect,
  selectedPlaceholders = []
}) => {
  const [searchQuery, setSearchQuery] = useState('');
  const [expandedCategories, setExpandedCategories] = useState<Set<string>>(new Set(['Formatore', 'Corso']));
  const [copiedKey, setCopiedKey] = useState<string | null>(null);

  // Filter placeholders by search query
  const filteredCategories = PLACEHOLDER_CATEGORIES.map(category => ({
    ...category,
    placeholders: category.placeholders.filter(p =>
      p.label.toLowerCase().includes(searchQuery.toLowerCase()) ||
      p.key.toLowerCase().includes(searchQuery.toLowerCase()) ||
      p.description.toLowerCase().includes(searchQuery.toLowerCase())
    )
  })).filter(category => category.placeholders.length > 0);

  const toggleCategory = (categoryName: string) => {
    const newExpanded = new Set(expandedCategories);
    if (newExpanded.has(categoryName)) {
      newExpanded.delete(categoryName);
    } else {
      newExpanded.add(categoryName);
    }
    setExpandedCategories(newExpanded);
  };

  const handleCopy = async (key: string) => {
    const placeholderText = `{{${key}}}`;
    await navigator.clipboard.writeText(placeholderText);
    setCopiedKey(key);
    setTimeout(() => setCopiedKey(null), 2000);
  };

  const handleSelect = (key: string) => {
    onSelect(`{{${key}}}`);
  };

  return (
    <div className="bg-white border border-gray-200 rounded-lg p-4">
      {/* Header */}
      <div className="mb-4">
        <h3 className="text-lg font-semibold text-gray-900 mb-2">Segnaposto Disponibili</h3>
        <p className="text-sm text-gray-600 mb-3">
          Seleziona o copia i segnaposto da inserire nel template. Verranno sostituiti automaticamente con i dati reali.
        </p>
        
        {/* Search */}
        <div className="relative">
          <Search className="absolute left-3 top-1/2 transform -translate-y-1/2 w-4 h-4 text-gray-400" />
          <input
            type="text"
            placeholder="Cerca segnaposto..."
            value={searchQuery}
            onChange={(e) => setSearchQuery(e.target.value)}
            className="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500"
          />
        </div>
      </div>

      {/* Categories */}
      <div className="space-y-2 max-h-96 overflow-y-auto">
        {filteredCategories.length === 0 ? (
          <p className="text-center text-gray-500 py-4">Nessun segnaposto trovato</p>
        ) : (
          filteredCategories.map((category) => (
            <div key={category.name} className="border border-gray-200 rounded-lg overflow-hidden">
              {/* Category Header */}
              <button
                onClick={() => toggleCategory(category.name)}
                className="w-full flex items-center justify-between p-3 bg-gray-50 hover:bg-gray-100 transition-colors"
              >
                <div className="flex items-center space-x-2">
                  <span className="text-xl">{category.icon}</span>
                  <span className="font-medium text-gray-900">{category.name}</span>
                  <span className="text-xs text-gray-500">({category.placeholders.length})</span>
                </div>
                {expandedCategories.has(category.name) ? (
                  <ChevronDown className="w-4 h-4 text-gray-500" />
                ) : (
                  <ChevronRight className="w-4 h-4 text-gray-500" />
                )}
              </button>

              {/* Category Placeholders */}
              {expandedCategories.has(category.name) && (
                <div className="p-2 space-y-1">
                  {category.placeholders.map((placeholder) => (
                    <div
                      key={placeholder.key}
                      className="flex items-center justify-between p-2 hover:bg-gray-50 rounded transition-colors group"
                    >
                      <div className="flex-1 min-w-0">
                        <div className="flex items-center space-x-2">
                          <code className="text-xs font-mono bg-blue-50 text-blue-700 px-2 py-1 rounded">
                            {'{{'}{placeholder.key}{'}}'}
                          </code>
                          <span className="text-sm font-medium text-gray-900">{placeholder.label}</span>
                        </div>
                        <p className="text-xs text-gray-500 mt-1">{placeholder.description}</p>
                        {placeholder.example && (
                          <p className="text-xs text-gray-400 mt-1">Es: {placeholder.example}</p>
                        )}
                      </div>

                      <div className="flex items-center space-x-1 opacity-0 group-hover:opacity-100 transition-opacity">
                        <button
                          onClick={() => handleSelect(placeholder.key)}
                          className="p-1.5 text-blue-600 hover:bg-blue-50 rounded transition-colors"
                          title="Inserisci nel template"
                        >
                          <svg className="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 4v16m8-8H4" />
                          </svg>
                        </button>
                        <button
                          onClick={() => handleCopy(placeholder.key)}
                          className="p-1.5 text-gray-600 hover:bg-gray-100 rounded transition-colors"
                          title="Copia negli appunti"
                        >
                          {copiedKey === placeholder.key ? (
                            <Check className="w-4 h-4 text-green-600" />
                          ) : (
                            <Copy className="w-4 h-4" />
                          )}
                        </button>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          ))
        )}
      </div>

      {/* Stats Footer */}
      <div className="mt-4 pt-3 border-t border-gray-200">
        <p className="text-xs text-gray-500 text-center">
          Totale: {PLACEHOLDER_CATEGORIES.reduce((sum, cat) => sum + cat.placeholders.length, 0)} segnaposto disponibili
        </p>
      </div>
    </div>
  );
};

export default PlaceholderSelector;
