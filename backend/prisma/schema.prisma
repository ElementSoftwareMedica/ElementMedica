/// Documento interno (procedure, moduli, materiale marketing)
/// Supporta versionamento: ogni revisione è un nuovo record con parentDocId che punta alla versione precedente
model InternalDocument {
  id               String               @id @default(uuid())
  tenantId         String
  folderId         String?
  nome             String
  descrizione      String?
  tipo             InternalDocumentTipo @default(ALTRO)
  fileUrl          String
  fileName         String
  fileSize         Int?
  mimeType         String?
  versione         String               @default("1.0")
  revisionNote     String?
  isCurrentVersion Boolean              @default(true)
  parentDocId      String?
  tags             String[]             @default([])
  isPublic         Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  createdBy        String?
  deletedAt        DateTime?
  folder           DocFolder?           @relation(fields: [folderId], references: [id])
  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, tipo])
  @@index([tenantId, folderId])
  @@index([tenantId, isCurrentVersion])
  @@map("internal_documents")
}

