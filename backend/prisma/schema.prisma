/// Esame strumentale acquisito tramite Medical Device Bridge
model EsameStrumentale {
  id              String                @id @default(uuid())
  /// Visita durante la quale è stato eseguito l'esame
  visitaId        String
  /// Paziente sottoposto all'esame
  pazienteId      String
  /// Medico che ha richiesto l'esame
  medicoId        String
  /// Tipo di dispositivo utilizzato
  tipoDispositivo TipoDispositivoMedico
  /// Tipo esame (ecg, spirometria, audiometria)
  tipoEsame       String
  /// Stato dell'esame
  stato           StatoEsameStrumentale @default(IN_ATTESA)
  /// Session ID dal Bridge
  bridgeSessionId String?
  /// Data e ora dell'esame (dal dispositivo)
  dataEsame       DateTime?
  /// Risultati singoli test (JSON: TestResult[])
  risultati       Json?                 @default("[]")
  /// Findings testuali dal dispositivo
  findings        String[]              @default([])
  /// Dati GDT grezzi (per debug/archiviazione)
  gdtRaw          Json?
  /// Percorso del file PDF del referto strumentale
  pdfPath         String?
  /// Nome originale del file PDF
  pdfFilename     String?
  /// Errore se stato = ERRORE
  errorMessage    String?
  /// Metadati aggiuntivi
  metadata        Json?                 @default("{}")
  /// Categoria esito clinico (ECG_NORMALE, AUDIO_G0..G5, SPIRO_OSTRUTTIVO_LIEVE, DRUG_TUTTI_NEGATIVI, …)
  categoriaEsito  String?
  /// Multi-tenancy
  tenantId        String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  deletedAt       DateTime?
  medico          Person                @relation("MedicoEsamiStrumentali", fields: [medicoId], references: [id])
  paziente        Person                @relation("PazienteEsamiStrumentali", fields: [pazienteId], references: [id])
  visita          Visita                @relation("VisitaEsamiStrumentali", fields: [visitaId], references: [id])

  @@index([tenantId])
  @@index([visitaId])
  @@index([pazienteId])
  @@index([tipoDispositivo])
  @@index([stato])
  @@index([dataEsame])
  @@index([tenantId, visitaId])
  @@map("esami_strumentali")
}

/// Licenza di attivazione per il Medical Device Bridge
/// Ogni licenza consente a un PC di attivare e usare il Bridge
model BridgeLicense {
  id           String              @id @default(uuid())
  /// Tenant proprietario della licenza
  tenantId     String
  /// Codice di attivazione (formato: ELEM-XXXX-XXXX-XXXX)
  licenseKey   String              @unique @db.VarChar(19)
  /// Etichetta descrittiva (es. "Ambulatorio 1 - PC Reception")
  label        String              @db.VarChar(100)
  /// Stato della licenza
  status       StatoBridgeLicense  @default(PENDING)
  /// API key univoca generata all'attivazione
  apiKey       String?             @unique
  /// Identificativo univoco della macchina (hash hardware)
  machineId    String?
  /// Hostname della macchina attivata
  machineName  String?
  /// Versione del Bridge installato
  bridgeVersion String?            @db.VarChar(20)
  /// Configurazione dispositivi (JSON: DeviceConfig[])
  deviceConfig Json?               @default("[]")
  /// Data di attivazione
  activatedAt  DateTime?           @db.Timestamp(6)
  /// Ultimo heartbeat ricevuto dal Bridge
  lastSeenAt   DateTime?           @db.Timestamp(6)
  /// Chi ha creato la licenza
  createdBy    String?
  createdAt    DateTime            @default(now()) @db.Timestamp(6)
  updatedAt    DateTime            @updatedAt @db.Timestamp(6)
  deletedAt    DateTime?           @db.Timestamp(6)

  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([licenseKey])
  @@map("bridge_licenses")
}

/// Licenza di attivazione per la Desktop App offline MDL
/// Ogni licenza consente a un PC di attivare e usare l'app desktop
model DesktopLicense {
  id             String                @id @default(uuid())
  /// Tenant proprietario della licenza
  tenantId       String
  /// Codice di attivazione (formato: DESK-XXXX-XXXX-XXXX)
  licenseKey     String                @unique @db.VarChar(19)
  /// Etichetta descrittiva (es. "Ambulatorio 3 - PC Medico")
  label          String                @db.VarChar(100)
  /// Stato della licenza
  status         StatoDesktopLicense   @default(PENDING)
  /// Tipo di licenza: solo app, solo bridge, o entrambi
  licenseType    TipoDesktopLicense    @default(APP_ONLY)
  /// Identificativo univoco della macchina (hash hardware)
  machineId      String?
  /// Hostname della macchina attivata
  machineName    String?
  /// Versione dell'app desktop installata
  appVersion     String?               @db.VarChar(20)
  /// Data di attivazione
  activatedAt    DateTime?             @db.Timestamp(6)
  /// Ultimo heartbeat (verifica licenza online)
  lastSeenAt     DateTime?             @db.Timestamp(6)
  /// Data scadenza abbonamento (copiata dal tenant al check)
  expiresAt      DateTime?             @db.Timestamp(6)
  /// Chi ha creato la licenza
  createdBy      String?
  createdAt      DateTime              @default(now()) @db.Timestamp(6)
  updatedAt      DateTime              @updatedAt @db.Timestamp(6)
  deletedAt      DateTime?             @db.Timestamp(6)

  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([tenantId, status])
  @@index([licenseKey])
  @@index([machineId])
  @@map("desktop_licenses")
}

