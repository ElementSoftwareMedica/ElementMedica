  isPublic              Boolean                @default(false)
  settings              Json?
  formFields            FormField[]
  persons               Person?                @relation(fields: [createdById], references: [id], onUpdate: NoAction)
  tenants               Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  courseTestAssignments CourseTestAssignment[]

  @@unique([tenantId, name, version])
  @@index([isActive])
  @@index([name])
  @@index([tenantId])
  @@index([type])
  @@map("form_templates")
}

/// Associazione tra form templates (test) e corsi
/// Permette di assegnare test specifici per riskLevel e courseType
model CourseTestAssignment {
  id             String      @id @default(uuid())
  formTemplateId String
  courseId       String? // Se specificato, test associato a un corso specifico
  riskLevel      RiskLevel? // Test per specifico livello di rischio
  courseType     CourseType? // Test per tipo corso (primo corso, aggiornamento)
  testType       TestType    @default(INITIAL) // Tipo test: iniziale, finale, intermedio
  isRequired     Boolean     @default(true) // Se il test è obbligatorio
  order          Int         @default(0) // Ordine di presentazione
  passingScore   Float? // Punteggio minimo per superare (es. 60%)
  timeLimit      Int? // Tempo limite in minuti
  isActive       Boolean     @default(true)
  tenantId       String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  formTemplate FormTemplate       @relation(fields: [formTemplateId], references: [id], onDelete: Cascade)
  course       Course?            @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  results      CourseTestResult[]

  @@unique([formTemplateId, courseId, riskLevel, courseType, testType, tenantId])
  @@index([tenantId])
  @@index([courseId])
  @@index([riskLevel])
  @@index([courseType])
  @@index([testType])
  @@index([formTemplateId])
  @@map("course_test_assignments")
}

/// Risultati dei test compilati dai partecipanti
model CourseTestResult {
  id                     String    @id @default(uuid())
  courseTestAssignmentId String
  scheduleId             String
  personId               String
  formSubmissionId       String? // Link alla submission del form
  score                  Float? // Punteggio ottenuto
  passed                 Boolean? // Se ha superato il test
  startedAt              DateTime?
  completedAt            DateTime?
  timeSpent              Int? // Tempo impiegato in secondi
  answers                Json? // Risposte date
  feedback               String? // Feedback aggiuntivo
  tenantId               String
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  assignment CourseTestAssignment @relation(fields: [courseTestAssignmentId], references: [id], onDelete: Cascade)
  schedule   CourseSchedule       @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  person     Person               @relation("CourseTestResult_Person", fields: [personId], references: [id], onDelete: Cascade)
  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([courseTestAssignmentId, scheduleId, personId])
  @@index([tenantId])
  @@index([scheduleId])
  @@index([personId])
  @@index([courseTestAssignmentId])
  @@index([passed])
  @@map("course_test_results")
}

