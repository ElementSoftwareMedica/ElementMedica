// ===========================================
// CLINICAL MODULE - MODELS
// ===========================================

model Poliambulatorio {
  id                   String               @id @default(uuid())
  codice               String
  nome                 String
  descrizione          String?
  indirizzo            String
  citta                String
  cap                  String
  provincia            String?
  telefono             String?
  email                String?
  pec                  String?
  piva                 String?
  codiceFiscale        String?
  direttoreSanitarioId String?
  stato                StatoPoliambulatorio @default(ATTIVO)
  orariApertura        Json?                @default("{}")
  branchType           BranchType           @default(MEDICA) @map("branch_type") // Progetto 45
  tenantId             String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?
  createdBy            String?

  sedi        SedePoliambulatorio[]
  ambulatori  Ambulatorio[]
  convenzioni ConvenzionePoliambulatorio[]
  listiniBase ListinoPrezzo[]

  @@unique([tenantId, codice])
  @@index([tenantId])
  @@index([tenantId, stato])
  @@index([tenantId, branchType]) // Progetto 45
  @@index([deletedAt])
  @@map("poliambulatori")
}

model SedePoliambulatorio {
  id                   String    @id @default(uuid())
  poliambulatorioId    String
  direttoreSanitarioId String? // Direttore Sanitario per questa sede (Person)
  nome                 String
  codice               String?
  indirizzo            String
  citta                String
  cap                  String
  provincia            String
  telefono             String?
  email                String?
  latitudine           Float?
  longitudine          Float?
  isPrincipale         Boolean   @default(false)
  isAttiva             Boolean   @default(true)
  oraAperturaOverride  String?
  oraChiusuraOverride  String?
  noteAccessibilita    String?
  tenantId             String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?
  createdBy            String?

  poliambulatorio    Poliambulatorio       @relation(fields: [poliambulatorioId], references: [id], onDelete: Cascade)
  direttoreSanitario Person?               @relation("SedeDirettoreSanitario", fields: [direttoreSanitarioId], references: [id], onDelete: SetNull)
  ambulatori         Ambulatorio[]
  orariSettimanali   OrarioSede[]          // Orari di apertura per ogni giorno della settimana
  chiusureSpeciali   ChiusuraSpecialeSede[] // Chiusure per festivi, ponti, ferie

  @@unique([tenantId, codice])
  @@index([tenantId])
  @@index([poliambulatorioId])
  @@index([isAttiva])
  @@index([direttoreSanitarioId])
  @@map("sedi_poliambulatorio")
}

// Orari di apertura settimanali della sede - supporta multiple fasce orarie per giorno
model OrarioSede {
  id              String    @id @default(uuid())
  sedeId          String
  giornoSettimana Int       // 0=Domenica, 1=Lunedì, 2=Martedì, 3=Mercoledì, 4=Giovedì, 5=Venerdì, 6=Sabato
  fascia          Int       @default(1) // 1=Prima fascia (es. mattina), 2=Seconda fascia (es. pomeriggio), 3+=fasce aggiuntive
  oraInizio       String    // Formato HH:MM (es. "08:30")
  oraFine         String    // Formato HH:MM (es. "12:30")
  isChiuso        Boolean   @default(false) // Se true, la sede è chiusa in questo giorno
  note            String?   // Note opzionali (es. "Solo su appuntamento")
  tenantId        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  sede SedePoliambulatorio @relation(fields: [sedeId], references: [id], onDelete: Cascade)

  @@unique([sedeId, giornoSettimana, fascia])
  @@index([tenantId])
  @@index([sedeId])
  @@index([giornoSettimana])
  @@map("orari_sede")
}

// Tipi di chiusura speciale
enum TipoChiusuraSpeciale {
  FESTIVITA         // Festività nazionali (Natale, Pasqua, etc.)
  PONTE             // Ponti (es. ponte 2 Giugno)
  FERIE_ESTIVE      // Chiusura estiva
  FERIE_NATALIZIE   // Chiusura natalizia
  FERIE_PASQUALI    // Chiusura pasquale
  STRAORDINARIA     // Chiusura straordinaria (es. ristrutturazione)
  FORMAZIONE        // Chiusura per formazione del personale
  EVENTO            // Chiusura per evento speciale
  ALTRO             // Altro tipo di chiusura
}

// Chiusure speciali della sede (festivi, ponti, ferie, etc.)
model ChiusuraSpecialeSede {
  id            String               @id @default(uuid())
  sedeId        String
  tipo          TipoChiusuraSpeciale
  nome          String               // Nome della chiusura (es. "Natale", "Ponte 2 Giugno")
  descrizione   String?              // Descrizione opzionale
  dataInizio    DateTime             // Data inizio chiusura (può essere singola giornata)
  dataFine      DateTime             // Data fine chiusura (per chiusure multi-giorno)
  oraInizio     String?              // Orario inizio chiusura (se chiusura parziale)
  oraFine       String?              // Orario fine chiusura (se chiusura parziale)
  isParziale    Boolean              @default(false) // Se true, chiusura solo in parte della giornata
  ricorrente    Boolean              @default(false) // Se true, si ripete ogni anno alla stessa data
  annoRiferimento Int?               // Anno di riferimento per chiusure ricorrenti
  attivo        Boolean              @default(true)
  tenantId      String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  deletedAt     DateTime?

  sede SedePoliambulatorio @relation(fields: [sedeId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sedeId])
  @@index([dataInizio, dataFine])
  @@index([tipo])
  @@index([ricorrente])
  @@map("chiusure_speciali_sede")
}

model Ambulatorio {
  id                String           @id @default(uuid())
  poliambulatorioId String
  sedeId            String?
  codice            String
  nome              String
  specializzazione  String?
  descrizione       String?
  piano             String?
  capacita          Int              @default(1)
  stato             StatoAmbulatorio @default(ATTIVO)
  colore            String?          @default("#3B82F6")
  tenantId          String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?

  poliambulatorio        Poliambulatorio          @relation(fields: [poliambulatorioId], references: [id], onDelete: Cascade)
  sede                   SedePoliambulatorio?     @relation(fields: [sedeId], references: [id])
  orari                  OrarioAmbulatorio[]
  strumenti              Strumento[]
  strumentiAssegnati     StrumentoAmbulatorio[]
  prestazioniAmbulatorio AmbulatorioPrestazione[]
  appuntamenti           Appuntamento[]
  visite                 Visita[]
  slotDisponibilita      SlotDisponibilita[]

  @@unique([poliambulatorioId, codice])
  @@index([tenantId])
  @@index([poliambulatorioId])
  @@index([specializzazione])
  @@index([stato])
  @@map("ambulatori")
}

model OrarioAmbulatorio {
  id              String    @id @default(uuid())
  ambulatorioId   String
  medicoId        String?
  giornoSettimana Int
  oraInizio       String
  oraFine         String
  durataSlot      Int       @default(30)
  attivo          Boolean   @default(true)
  validoDa        DateTime?
  validoA         DateTime?
  tenantId        String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  ambulatorio Ambulatorio @relation(fields: [ambulatorioId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([ambulatorioId])
  @@index([medicoId])
  @@index([giornoSettimana])
  @@map("orari_ambulatorio")
}

model Prestazione {
  id                     String          @id @default(uuid())
  codice                 String
  nome                   String
  descrizione            String?
  tipo                   TipoPrestazione
  brancheSpecialistiche  String[]        @default([]) // Array di specialità (es. ["Cardiologia", "Medicina Interna"])
  durataPrevista         Int             @default(30)
  prezzoBase             Decimal         @db.Decimal(10, 2)
  ivaAliquota            Decimal         @default(0) @db.Decimal(5, 2)
  attivo                 Boolean         @default(true)
  istruzioniPreparazione String?
  richiedeStrumento      Boolean         @default(false)
  strumentiRichiesti     String[]        @default([])
  branchType             BranchType      @default(MEDICA) @map("branch_type") // Progetto 45
  tenantId               String
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  deletedAt              DateTime?
  createdBy              String?

  ambulatori         AmbulatorioPrestazione[]
  listiniPrezzo      ListinoPrezzo[]
  mediciAbilitati    MedicoAbilitato[]
  appuntamenti       Appuntamento[]
  visite             Visita[]
  strumentiNecessari PrestazioneStrumento[]
  tipologieRichieste PrestazioneTipologiaStrumento[] @relation("PrestazioneTipologie") // Tipologie strumenti richieste
  bundlePrestazioni  OffertaBundlePrestazione[] // Tariffario: bundle/offerte
  riconoscimenti     RiconoscimentoConvenzione[] // Riconoscimenti convenzioni
  vociTariffario     VoceTariffario[]            // Voci tariffario aziende
  slotDisponibilita  SlotDisponibilita[]         // Slot disponibilità

  @@unique([tenantId, codice])
  @@index([tenantId])
  @@index([tenantId, branchType]) // Progetto 45
  @@index([tipo])
  @@index([attivo])
  @@map("prestazioni")
}

model AmbulatorioPrestazione {
  id            String    @id @default(uuid())
  ambulatorioId String
  prestazioneId String
  attivo        Boolean   @default(true)
  tenantId      String
  createdAt     DateTime  @default(now())
  deletedAt     DateTime?

  ambulatorio Ambulatorio @relation(fields: [ambulatorioId], references: [id], onDelete: Cascade)
  prestazione Prestazione @relation(fields: [prestazioneId], references: [id], onDelete: Cascade)

  @@unique([ambulatorioId, prestazioneId])
  @@index([tenantId])
  @@map("ambulatorio_prestazioni")
}

model MedicoAbilitato {
  id               String   @id @default(uuid())
  medicoId         String
  prestazioneId    String
  attivo           Boolean  @default(true)
  dataAbilitazione DateTime @default(now())

  // Durata specifica per questo medico (override della durata prestazione)
  durataMedico Int? // In minuti, null = usa durataPrevista della prestazione

  // Compenso default per questo medico su questa prestazione
  compensoTipo    TipoCompensoMedico @default(PERCENTUALE)
  compensoValore  Decimal            @default(30) @db.Decimal(10, 2) // Default 30%
  compensoMinimo  Decimal?           @db.Decimal(10, 2)
  compensoMassimo Decimal?           @db.Decimal(10, 2)

  note String?

  tenantId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  prestazione Prestazione @relation(fields: [prestazioneId], references: [id], onDelete: Cascade)
  medico      Person      @relation("MedicoAbilitazioni", fields: [medicoId], references: [id], onDelete: Cascade)

  @@unique([medicoId, prestazioneId])
  @@index([tenantId])
  @@index([medicoId])
  @@map("medici_abilitati")
}

model Strumento {
  id                    String              @id @default(uuid())
  codice                String
  nome                  String
  descrizione           String?
  tipologia             TipologiaStrumento? // Categoria dello strumento (ECOGRAFO, ECG, LASER, etc.)
  marca                 String?
  modello               String?
  numeroSerie           String?
  ambulatorioId         String?
  stato                 StatoStrumento      @default(ATTIVO)
  dataAcquisto          DateTime?
  costoAcquisto         Decimal?            @db.Decimal(10, 2)
  dataFineAmmortamento  DateTime?
  ultimaManutenzione    DateTime?
  prossimaManutenzione  DateTime?
  intervallManutenzione Int?
  ultimaTaratura        DateTime?
  prossimaTaratura      DateTime?
  branchType            BranchType          @default(MEDICA) @map("branch_type") // Progetto 45
  tenantId              String
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  deletedAt             DateTime?
  createdBy             String?

  ambulatorio          Ambulatorio?            @relation(fields: [ambulatorioId], references: [id])
  ambulatoriAssegnati  StrumentoAmbulatorio[]
  manutenzioni         ManutenzioneStrumento[]
  prestazioniStrumento PrestazioneStrumento[]

  @@unique([tenantId, codice])
  @@index([tenantId])
  @@index([tenantId, branchType]) // Progetto 45
  @@index([ambulatorioId])
  @@index([stato])
  @@index([tipologia])
  @@map("strumenti")
}

model StrumentoAmbulatorio {
  id                   String    @id @default(uuid())
  strumentoId          String
  ambulatorioId        String
  isPermanente         Boolean   @default(true)
  dataAssegnazione     DateTime  @default(now())
  dataFineAssegnazione DateTime?
  note                 String?
  tenantId             String
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  strumento   Strumento   @relation(fields: [strumentoId], references: [id], onDelete: Cascade)
  ambulatorio Ambulatorio @relation(fields: [ambulatorioId], references: [id], onDelete: Cascade)

  @@unique([strumentoId, ambulatorioId])
  @@index([tenantId])
  @@index([strumentoId])
  @@index([ambulatorioId])
  @@map("strumenti_ambulatori")
}

model ManutenzioneStrumento {
  id                String            @id @default(uuid())
  strumentoId       String
  tipo              TipoManutenzione  @default(PROGRAMMATA)
  descrizione       String
  dataProgrammata   DateTime?
  dataEsecuzione    DateTime?
  durataOre         Float?
  esecutore         String?
  contattoEsecutore String?
  costoManodopera   Decimal?          @db.Decimal(8, 2)
  costoRicambi      Decimal?          @db.Decimal(8, 2)
  costoTotale       Decimal?          @db.Decimal(10, 2)
  numeroFattura     String?
  stato             StatoManutenzione @default(PROGRAMMATA)
  esitoNote         String?
  prossimaScadenza  DateTime?
  rapportoUrl       String?
  tenantId          String
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  deletedAt         DateTime?
  createdBy         String?

  strumento Strumento @relation(fields: [strumentoId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([strumentoId])
  @@index([stato])
  @@index([dataProgrammata])
  @@map("manutenzioni_strumenti")
}

model PrestazioneStrumento {
  id             String    @id @default(uuid())
  prestazioneId  String
  strumentoId    String
  isObbligatorio Boolean   @default(false)
  note           String?
  tenantId       String
  createdAt      DateTime  @default(now())
  deletedAt      DateTime?

  prestazione Prestazione @relation(fields: [prestazioneId], references: [id], onDelete: Cascade)
  strumento   Strumento   @relation(fields: [strumentoId], references: [id], onDelete: Cascade)

  @@unique([prestazioneId, strumentoId])
  @@index([tenantId])
  @@map("prestazioni_strumenti")
}

// Requisiti tipologia strumento per prestazione
// Collega una Prestazione a una TipologiaStrumento richiesta (non strumento specifico)
model PrestazioneTipologiaStrumento {
  id              String             @id @default(uuid())
  prestazioneId   String
  tipologia       TipologiaStrumento // Tipologia strumento richiesta (ECOGRAFO, ECG, etc.)
  isObbligatorio  Boolean            @default(true) // Se la tipologia è obbligatoria per eseguire la prestazione
  quantitaMinima  Int                @default(1) // Numero minimo di strumenti di questa tipologia
  note            String?
  tenantId        String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  deletedAt       DateTime?

  prestazione Prestazione @relation("PrestazioneTipologie", fields: [prestazioneId], references: [id], onDelete: Cascade)

  @@unique([prestazioneId, tipologia])
  @@index([tenantId])
  @@index([tipologia])
  @@map("prestazioni_tipologie_strumenti")
}

model ListinoPrezzo {
  id                String  @id @default(uuid())
  prestazioneId     String? // Opzionale: per listino per prestazione singola
  bundleId          String? // Opzionale: per listino per bundle (Tariffario Avanzato)
  poliambulatorioId String?
  convenzioneId     String?
  medicoId          String? // Prezzo specifico per medico (Tariffario Avanzato)

  // Identificazione
  codice      String? // Per riferimento rapido (es. "CONV-ACME-2025")
  nome        String?
  descrizione String? // Note aggiuntive

  // Pricing
  prezzo            Decimal  @db.Decimal(10, 2)
  ivaAliquota       Decimal  @default(0) @db.Decimal(5, 2)
  scontoPercentuale Decimal? @db.Decimal(5, 2) // Sconto sul prezzo base

  // Durata specifica per questo medico (override della durata prestazione)
  durataMedico Int? // In minuti, null = usa durataPrevista della prestazione

  // Compenso medico (override per questo listino)
  compensoMedicoTipo    TipoCompensoMedico?
  compensoMedicoValore  Decimal?            @db.Decimal(10, 2)
  compensoMedicoMinimo  Decimal?            @db.Decimal(10, 2)
  compensoMedicoMassimo Decimal?            @db.Decimal(10, 2)

  // Validità e priorità
  attivo   Boolean   @default(true)
  validoDa DateTime  @default(now())
  validoA  DateTime?
  priorita Int       @default(0) // Per risolvere conflitti (più alto = priorità maggiore)

  tenantId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String? // Audit

  branchType BranchType @default(MEDICA) @map("branch_type") // Progetto 45

  // Relations
  prestazione     Prestazione?     @relation(fields: [prestazioneId], references: [id], onDelete: Cascade)
  bundle          OffertaBundle?   @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  poliambulatorio Poliambulatorio? @relation(fields: [poliambulatorioId], references: [id])
  convenzione     Convenzione?     @relation(fields: [convenzioneId], references: [id])
  medico          Person?          @relation("ListinoMedico", fields: [medicoId], references: [id])

  @@index([tenantId])
  @@index([tenantId, branchType]) // Progetto 45
  @@index([prestazioneId])
  @@index([bundleId])
  @@index([poliambulatorioId])
  @@index([convenzioneId])
  @@index([medicoId])
  @@index([attivo])
  @@index([tenantId, prestazioneId, medicoId])
  @@index([tenantId, bundleId, medicoId])
  @@index([tenantId, prestazioneId, convenzioneId])
  @@map("listini_prezzo")
}

// Tariffario: Bundle/Offerte (Pacchetti di prestazioni)
model OffertaBundle {
  id          String  @id @default(uuid())
  codice      String
  nome        String
  descrizione String?

  // Pricing bundle
  prezzoBundle      Decimal? @db.Decimal(10, 2) // Prezzo fisso bundle
  scontoPercentuale Decimal? @db.Decimal(5, 2) // Alternativa: % sconto su somma
  ivaAliquota       Decimal  @default(0) @db.Decimal(5, 2)

  // Durata esecuzione bundle (in minuti)
  durataBundle Int? // Durata totale esecuzione bundle, null = somma durate prestazioni

  // Compenso medico per bundle (opzionale)
  compensoMedicoTipo    TipoCompensoMedico?
  compensoMedicoValore  Decimal?            @db.Decimal(10, 2)
  compensoMedicoMinimo  Decimal?            @db.Decimal(10, 2)
  compensoMedicoMassimo Decimal?            @db.Decimal(10, 2)

  // Validità
  attivo   Boolean   @default(true)
  validoDa DateTime  @default(now())
  validoA  DateTime?

  // Applicabilità (Enhanced Progetto 44)
  soloNuoviPazienti Boolean  @default(false)
  maxUtilizzi       Int? // Limite globale
  utilizziCorrente  Int      @default(0)
  etaMinima         Int? // Età minima paziente
  etaMassima        Int? // Età massima paziente
  genereApplicabile Gender? // Solo per genere specifico
  convenzioniIds    String[] @default([]) // Convenzioni compatibili

  // Codici sconto applicabili al bundle
  codiciScontoIds String[] @default([]) // CodiceSconto IDs applicabili

  branchType BranchType @default(MEDICA) @map("branch_type") // Progetto 45
  tenantId   String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?
  createdBy  String?

  prestazioni OffertaBundlePrestazione[]
  listini     ListinoPrezzo[]            // Listini specifici per questo bundle
  riconoscimenti RiconoscimentoConvenzione[] // Riconoscimenti per questo bundle

  @@unique([tenantId, codice])
  @@index([tenantId])
  @@index([tenantId, branchType]) // Progetto 45
  @@index([tenantId, attivo])
  @@index([tenantId, validoDa, validoA])
  @@map("offerte_bundle")
}

model OffertaBundlePrestazione {
  id              String    @id @default(uuid())
  offertaBundleId String
  prestazioneId   String
  quantita        Int       @default(1) // Quante volte questa prestazione nel bundle
  obbligatoria    Boolean   @default(true) // false = opzionale
  ordine          Int       @default(0) // Ordine di esecuzione consigliato
  tenantId        String
  createdAt       DateTime  @default(now())
  deletedAt       DateTime?

  offertaBundle OffertaBundle @relation(fields: [offertaBundleId], references: [id], onDelete: Cascade)
  prestazione   Prestazione   @relation(fields: [prestazioneId], references: [id], onDelete: Cascade)

  @@unique([offertaBundleId, prestazioneId])
  @@index([tenantId])
  @@index([prestazioneId])
  @@map("offerte_bundle_prestazioni")
}

// Tariffario Medico: Configurazione compensi di default per medico
// Usato per impostare i default quando si crea un ListinoPrezzo per questo medico
model TariffarioMedico {
  id       String @id @default(uuid())
  medicoId String

  // Compenso default per questo medico
  compensoMedicoTipo    TipoCompensoMedico @default(PERCENTUALE)
  compensoMedicoValore  Decimal            @db.Decimal(10, 2) // Es: 30 per 30%
  compensoMedicoMinimo  Decimal?           @db.Decimal(10, 2) // Floor (opzionale)
  compensoMedicoMassimo Decimal?           @db.Decimal(10, 2) // Ceiling (opzionale)

  // Applicabilità
  brancaSpecialistica String? // Se specificato, solo per questa branca
  convenzioneId       String? // Se specificato, solo per questa convenzione

  // Metadati
  note     String?
  attivo   Boolean   @default(true)
  validoDa DateTime  @default(now())
  validoA  DateTime?

  branchType BranchType @default(MEDICA) @map("branch_type") // Progetto 45
  tenantId   String
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?
  createdBy  String?

  medico      Person       @relation("TariffarioMedico", fields: [medicoId], references: [id], onDelete: Cascade)
  convenzione Convenzione? @relation(fields: [convenzioneId], references: [id])

  @@index([tenantId])
  @@index([tenantId, branchType]) // Progetto 45
  @@index([medicoId])
  @@index([tenantId, medicoId, attivo])
  @@index([tenantId, brancaSpecialistica])
  @@map("tariffari_medico")
}

model Convenzione {
  id            String          @id @default(uuid())
  codice        String
  nome          String
  descrizione   String?
  tipo          TipoConvenzione
  enteTerzo     String?
  partitaIva    String?
  codiceFiscale String?
  telefono      String?
  email         String?
  referente     String?
  dataInizio    DateTime
  dataFine      DateTime?
  attiva        Boolean         @default(true)
  condizioni    Json?           @default("{}")
  branchType    BranchType      @default(MEDICA) @map("branch_type") // Progetto 45
  tenantId      String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  deletedAt     DateTime?
  createdBy     String?

  poliambulatori     ConvenzionePoliambulatorio[]
  listiniPrezzo      ListinoPrezzo[]
  tariffariMedico    TariffarioMedico[]
  aziende            ConvenzioneAzienda[]
  tariffariAziendali TariffarioAziendale[]

  @@unique([tenantId, codice])
  @@index([tenantId])
  @@index([tenantId, branchType]) // Progetto 45
  @@index([tipo])
  @@index([attiva])
  @@map("convenzioni")
}

model ConvenzionePoliambulatorio {
  id                String    @id @default(uuid())
  convenzioneId     String
  poliambulatorioId String
  attiva            Boolean   @default(true)
  tenantId          String
  createdAt         DateTime  @default(now())
  deletedAt         DateTime?

  convenzione     Convenzione     @relation(fields: [convenzioneId], references: [id], onDelete: Cascade)
  poliambulatorio Poliambulatorio @relation(fields: [poliambulatorioId], references: [id], onDelete: Cascade)

  @@unique([convenzioneId, poliambulatorioId])
  @@index([tenantId])
  @@map("convenzione_poliambulatori")
}

// Relazione many-to-many tra Convenzione e Azienda (Company)
// Sostituisce il campo JSON condizioni.companyIds
model ConvenzioneAzienda {
  id            String   @id @default(uuid())
  convenzioneId String
  aziendaId     String
  
  // Opzioni specifiche per questa azienda in convenzione
  referenteAziendale  String?   // Referente specifico per l'azienda
  emailReferente      String?
  telefonoReferente   String?
  note                String?   // Note specifiche per questa azienda
  dataAdesione        DateTime  @default(now()) // Quando l'azienda ha aderito
  dataFineAdesione    DateTime? // Se l'adesione ha una scadenza specifica
  attiva              Boolean   @default(true)
  
  tenantId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  convenzione Convenzione @relation(fields: [convenzioneId], references: [id], onDelete: Cascade)
  azienda     Company     @relation(fields: [aziendaId], references: [id], onDelete: Cascade)

  riconoscimenti RiconoscimentoConvenzione[]

  @@unique([convenzioneId, aziendaId])
  @@index([tenantId])
  @@index([convenzioneId])
  @@index([aziendaId])
  @@map("convenzione_aziende")
}

// Definizione dei riconoscimenti per bundle o prestazione
// Un'azienda in convenzione può ricevere riconoscimenti/premi
model RiconoscimentoConvenzione {
  id                   String             @id @default(uuid())
  convenzioneAziendaId String
  
  // Può essere associato a un bundle O a una prestazione (mutualmente esclusivi)
  bundleId      String?
  prestazioneId String?
  
  // Tipo e valore del riconoscimento
  tipo           TipoRiconoscimento
  valore         Decimal            @db.Decimal(10, 2) // Percentuale (0-100) o valore assoluto in euro
  
  // Limiti opzionali
  valoreMinimo   Decimal?           @db.Decimal(10, 2) // Minimo riconoscimento (per percentuale)
  valoreMassimo  Decimal?           @db.Decimal(10, 2) // Massimo riconoscimento (per percentuale)
  
  // Validità temporale
  dataInizio     DateTime           @default(now())
  dataFine       DateTime?
  attivo         Boolean            @default(true)
  
  // Note e descrizione
  descrizione    String?
  note           String?
  
  tenantId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  createdBy String?

  convenzioneAzienda  ConvenzioneAzienda  @relation(fields: [convenzioneAziendaId], references: [id], onDelete: Cascade)
  bundle              OffertaBundle?      @relation(fields: [bundleId], references: [id], onDelete: SetNull)
  prestazione         Prestazione?        @relation(fields: [prestazioneId], references: [id], onDelete: SetNull)

  riconoscimentiErogati RiconoscimentoErogato[]

  @@index([tenantId])
  @@index([convenzioneAziendaId])
  @@index([bundleId])
  @@index([prestazioneId])
  @@index([tenantId, attivo])
  @@map("riconoscimenti_convenzione")
}

// Tracking dei riconoscimenti erogati per ogni paziente/prestazione
model RiconoscimentoErogato {
  id                        String              @id @default(uuid())
  riconoscimentoConvenzioneId String
  
  // Riferimenti al paziente e alla prestazione/appuntamento
  pazienteId    String                          // Person.id del paziente
  appuntamentoId String?                        // Collegamento all'appuntamento se disponibile
  
  // Importo calcolato e stato
  importoCalcolato Decimal            @db.Decimal(10, 2) // Importo effettivo del riconoscimento
  importoBase      Decimal            @db.Decimal(10, 2) // Prezzo su cui è stato calcolato
  stato            StatoRiconoscimento @default(DA_EROGARE)
  
  // Date di tracking
  dataCalcolo   DateTime  @default(now()) // Quando è stato calcolato
  dataErogazione DateTime? // Quando è stato effettivamente erogato
  
  // Note per audit
  note          String?
  
  tenantId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  
  riconoscimentoConvenzione RiconoscimentoConvenzione @relation(fields: [riconoscimentoConvenzioneId], references: [id], onDelete: Cascade)
  paziente                  Person                    @relation("RiconoscimentiPaziente", fields: [pazienteId], references: [id])

  @@index([tenantId])
  @@index([riconoscimentoConvenzioneId])
  @@index([pazienteId])
  @@index([stato])
  @@index([tenantId, stato, dataCalcolo])
  @@map("riconoscimenti_erogati")
}

model SlotDisponibilita {
  id             String     @id @default(uuid())
  ambulatorioId  String
  medicoId       String
  prestazioneId  String?
  appuntamentoId String?
  data           DateTime   @db.Date
  oraInizio      String
  oraFine        String
  stato          StatoSlot  @default(LIBERO)
  disponibile    Boolean    @default(true)
  motivoBlocco   String?
  note           String?
  tenantId       String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?

  // Relations
  ambulatorio  Ambulatorio   @relation(fields: [ambulatorioId], references: [id], onDelete: Cascade)
  medico       Person        @relation("SlotMedico", fields: [medicoId], references: [id], onDelete: Cascade)
  prestazione  Prestazione?  @relation(fields: [prestazioneId], references: [id], onDelete: SetNull)
  appuntamento Appuntamento? @relation(fields: [appuntamentoId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([ambulatorioId])
  @@index([medicoId])
  @@index([data])
  @@index([stato])
  @@index([data, medicoId])
  @@index([tenantId, stato, deletedAt])
  @@map("slot_disponibilita")
}

model Appuntamento {
  id                 String            @id @default(uuid())
  numeroPrenotazione String
  ambulatorioId      String
  prestazioneId      String
  pazienteId         String
  medicoId           String
  dataOra            DateTime
  durataMinuti       Int               @default(30)
  stato              StatoAppuntamento @default(PRENOTATO)
  note               String?
  noteInterne        String?
  convenzioneId      String?
  promemoriaSms      Boolean           @default(false)
  promemoriaEmail    Boolean           @default(true)
  promemoriaInviato  DateTime?
  oraArrivo          DateTime?
  oraChiamata        DateTime?
  oraInizio          DateTime?
  oraFine            DateTime?
  tenantId           String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deletedAt          DateTime?
  createdBy          String?

  ambulatorio Ambulatorio        @relation(fields: [ambulatorioId], references: [id])
  prestazione Prestazione        @relation(fields: [prestazioneId], references: [id])
  slots       SlotDisponibilita[]
  visita      Visita?

  @@unique([tenantId, numeroPrenotazione])
  @@index([tenantId])
  @@index([ambulatorioId])
  @@index([pazienteId])
  @@index([medicoId])
  @@index([dataOra])
  @@index([stato])
  @@index([tenantId, dataOra])
  @@index([medicoId, dataOra])
  @@map("appuntamenti")
}

model Visita {
  id                 String      @id @default(uuid())
  appuntamentoId     String?     @unique
  ambulatorioId      String
  prestazioneId      String
  pazienteId         String
  medicoId           String
  dataOra            DateTime
  durataEffettiva    Int?
  stato              StatoVisita @default(IN_CORSO)
  anamnesi           String?
  esamiObiettivo     String?
  diagnosiPrincipale String?
  diagnosiSecondarie String[]    @default([])
  terapia            String?
  noteClinico        String?
  datiStrutturati    Json?       @default("{}")
  templateUsato      String?
  prescrizioni       String?
  prossimoControllo  DateTime?
  noteFollowup       String?
  tenantId           String
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?
  createdBy          String?

  appuntamento       Appuntamento?      @relation(fields: [appuntamentoId], references: [id])
  ambulatorio        Ambulatorio        @relation(fields: [ambulatorioId], references: [id])
  prestazione        Prestazione        @relation(fields: [prestazioneId], references: [id])
  paziente           Person             @relation("VisitaPaziente", fields: [pazienteId], references: [id])
  medico             Person             @relation("VisitaMedico", fields: [medicoId], references: [id])
  referti            Referto[]
  documenti          DocumentoClinico[] // Legacy - deprecato, usare documentiUnificati
  documentiUnificati PersonDocument[]   @relation("VisitaDocuments")
  fatture            FatturaSanitaria[]

  @@index([tenantId])
  @@index([pazienteId])
  @@index([medicoId])
  @@index([dataOra])
  @@index([stato])
  @@index([ambulatorioId])
  @@map("visite")
}

model Referto {
  id               String       @id @default(uuid())
  visitaId         String
  numeroReferto    String
  titolo           String
  contenuto        String
  conclusioni      String?
  allegati         Json?        @default("[]")
  stato            StatoReferto @default(BOZZA)
  dataFirma        DateTime?
  firmatoBy        String?
  hashFirma        String?
  dataConsegna     DateTime?
  modalitaConsegna String?
  tenantId         String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?
  createdBy        String?

  visita Visita @relation(fields: [visitaId], references: [id], onDelete: Cascade)

  @@unique([tenantId, numeroReferto])
  @@index([tenantId])
  @@index([visitaId])
  @@index([stato])
  @@map("referti")
}

model TemplateCampoVisita {
  id               String           @id @default(uuid())
  codice           String
  nome             String
  descrizione      String?
  tipoPrestazione  TipoPrestazione?
  specializzazione String?
  schema           Json
  attivo           Boolean          @default(true)
  versione         Int              @default(1)
