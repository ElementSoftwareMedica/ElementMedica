// PHASE 3: ENTITÀ AGENDA E DISPONIBILITÀ (SPEC_05)
// ============================================================================

enum TipoAssenza {
  FERIE
  MALATTIA
  PERMESSO
  CONGEDO_PARENTALE
  FORMAZIONE
  ALTRO

  @@map("tipo_assenza")
}

enum StatoAssenza {
  RICHIESTA
  APPROVATA
  RIFIUTATA
  CANCELLATA

  @@map("stato_assenza")
}

model DisponibilitaMedico {
  id              String     @id @default(uuid())
  medicoId        String
  ambulatorioId   String?
  prestazioneId   String?
  giorno          Int // 0=Dom, 1=Lun...6=Sab
  oraInizio       String // HH:mm
  oraFine         String // HH:mm
  durataSlot      Int        @default(30) // minuti
  intervalloSlot  Int        @default(0) // pausa tra slot
  maxAppuntamenti Int? // limite giornaliero
  attivo          Boolean    @default(true)
  validoDal       DateTime?
  validoAl        DateTime?
  note            String?
  branchType      BranchType @default(MEDICA) @map("branch_type") // Progetto 45
  tenantId        String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?
  createdBy       String?

  @@index([tenantId])
  @@index([tenantId, branchType]) // Progetto 45
  @@index([medicoId])
  @@index([ambulatorioId])
  @@index([giorno])
  @@index([tenantId, deletedAt])
  @@map("disponibilita_medici")
}

model FerieAssenza {
  id               String       @id @default(uuid())
  medicoId         String
  tipo             TipoAssenza  @default(FERIE)
  stato            StatoAssenza @default(RICHIESTA)
  dataInizio       DateTime
  dataFine         DateTime
  orarioInizio     String? // per permessi parziali (HH:mm)
  orarioFine       String? // per permessi parziali (HH:mm)
  giornataIntera   Boolean      @default(true)
  motivazione      String?
  approvatoDa      String?
  dataApprovazione DateTime?
  note             String?
  branchType       BranchType   @default(MEDICA) @map("branch_type") // Progetto 45
  tenantId         String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?
  createdBy        String?

  @@index([tenantId])
  @@index([tenantId, branchType]) // Progetto 45
  @@index([medicoId])
  @@index([tipo])
  @@index([stato])
  @@index([dataInizio, dataFine])
  @@index([tenantId, deletedAt])
  @@map("ferie_assenze")
}

// ============================================================================
