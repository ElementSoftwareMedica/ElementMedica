{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "isolatedModules": true,
        "esModuleInterop": true
    },
    "include": [
        "src/main/**/*.ts",
        "src/preload/**/*.ts"
    ]
}