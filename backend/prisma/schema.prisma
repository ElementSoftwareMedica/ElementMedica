  READ // Solo lettura
  WRITE // Lettura + scrittura
  ADMIN // Amministratore del tenant
  FULL // Accesso completo (come il proprietario)

  @@map("tenant_access_levels")
}

// Modello per gestire accesso utente a multipli tenant
model PersonTenantAccess {
  id          String            @id @default(uuid())
  personId    String
  tenantId    String
  accessLevel TenantAccessLevel @default(READ)

  // Features abilitate per questo utente in questo tenant
  // Es: ["formazione", "medica", "fatturazione"]
  // DEPRECATO: Usare enabledBranches per controllo branch
  enabledFeatures String[] @default([])

  // Branch commerciali abilitati per questo utente (Progetto 45)
  // Intersezione con Tenant.enabledBranches per l'accesso effettivo
  enabledBranches BranchType[] @default([]) @map("enabled_branches")

  // Ruolo specifico in questo tenant (opzionale)
  // Se null, usa i PersonRole standard
  defaultRoleType RoleType?

  // Permessi personalizzati (override)
  customPermissions Json? @default("{}")

  // Restrizioni specifiche
  restrictions Json? @default("{}")

  // Metadata
  isActive     Boolean   @default(true)
  isPrimary    Boolean   @default(false) // Tenant principale
  grantedBy    String? // Chi ha concesso l'accesso
  grantedAt    DateTime  @default(now())
  validFrom    DateTime  @default(now())
  validUntil   DateTime? // Accesso temporaneo
  lastAccessAt DateTime? // Ultimo accesso

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  person          Person  @relation("PersonTenantAccesses", fields: [personId], references: [id], onDelete: Cascade)
  tenant          Tenant  @relation("TenantPersonAccesses", fields: [tenantId], references: [id], onDelete: Cascade)
  grantedByPerson Person? @relation("GrantedTenantAccesses", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@unique([personId, tenantId])
  @@index([personId])
  @@index([tenantId])
  @@index([personId, isActive])
  @@index([tenantId, isActive])
  @@index([accessLevel])
  @@index([grantedBy])
  @@index([deletedAt])
  @@map("person_tenant_accesses")
}

