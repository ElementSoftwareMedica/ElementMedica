  ipAddress  String?
  userAgent  String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, action])
  @@index([tenantId, createdAt])
  @@index([userId, action])
}

model DataRetentionPolicy {
