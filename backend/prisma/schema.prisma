  dvrId                   String?
  nominaRuoloId           String?
  consulenzaId            String?
  courseScheduleId        String?
  bundleId                String?
  giudizioIdoneitaId      String?
  allegato3bId            String?
  refertoId               String?
  documentoCompilatoId    String?
  tipoSoggetto            TipoSoggettoMovimento
  personId                String?
  companyTenantProfileId  String?
  siteId                  String?
  movimentoCollegatoId    String?                  @unique
  importoLordo            Decimal                  @db.Decimal(10, 2)
  aliquotaIva             Decimal                  @default(22) @db.Decimal(5, 2)
  importoIva              Decimal                  @default(0) @db.Decimal(10, 2)
  importoNetto            Decimal                  @db.Decimal(10, 2)
  ritenutaAcconto         Decimal?                 @db.Decimal(10, 2)
  importoDaPagare         Decimal?                 @db.Decimal(10, 2)
  scontoApplicato         Decimal?                 @db.Decimal(10, 2)
  scontoMotivo            String?
  compensoTipo            TipoCompensoMedico?
  compensoValore          Decimal?                 @db.Decimal(10, 2)
  importoRiferimento      Decimal?                 @db.Decimal(10, 2)
  dataEsecuzione          DateTime
  dataRegistrazione       DateTime                 @default(now())
  dataScadenza            DateTime?
  dataFatturazione        DateTime?
  dataPagamento           DateTime?
  fatturaElettronicaId    String?
  preventivoId            String?
  numeroFatturaRicevuta   String?
  dataFatturaRicevuta     DateTime?
  fileFatturaRicevuta     String?
  voceTariffarioId        String?
  tariffarioMedicoId      String?
  listinoId               String?
  metodoPagamento         String?
  riferimentoPagamento    String?
  descrizione             String?
  note                    String?
  branchType              BranchType               @default(MEDICA)
  tenantId                String
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  deletedAt               DateTime?
  createdBy               String?
  updatedBy               String?
  allegato3B              Allegato3B?              @relation(fields: [allegato3bId], references: [id])
  appuntamentoPrestazione AppuntamentoPrestazione? @relation(fields: [appPrestazioneId], references: [id])
  appuntamento            Appuntamento?            @relation(fields: [appuntamentoId], references: [id])
  offertaBundle           OffertaBundle?           @relation(fields: [bundleId], references: [id])
  companyTenantProfile    CompanyTenantProfile?    @relation(fields: [companyTenantProfileId], references: [id])
  consulenza              ConsulenzaMDL?           @relation(fields: [consulenzaId], references: [id])
  courseSchedule          CourseSchedule?          @relation(fields: [courseScheduleId], references: [id])
  documentoCompilato      DocumentoCompilato?      @relation(fields: [documentoCompilatoId], references: [id])
  dvr                     DVR?                     @relation(fields: [dvrId], references: [id])
  fatturaElettronica      FatturaElettronica?      @relation("MovimentoFattura", fields: [fatturaElettronicaId], references: [id])
  giudizioIdoneita        GiudizioIdoneita?        @relation(fields: [giudizioIdoneitaId], references: [id])
  listinoPrezzo           ListinoPrezzo?           @relation(fields: [listinoId], references: [id])
  movimentoCollegato      MovimentoContabile?      @relation("MovimentoCollegato", fields: [movimentoCollegatoId], references: [id])
