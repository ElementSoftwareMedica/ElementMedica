  profiloHRId       String
  tenantId          String
  data              DateTime         @db.Date
  turnoTemplateId   String?
  mansioneInternaId String?
  oraInizio         String           @db.VarChar(5)
  oraFine           String           @db.VarChar(5)
  pausaPranzoInizio String?          @db.VarChar(5)
  pausaPranzoFine   String?          @db.VarChar(5)
