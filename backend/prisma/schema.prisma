// Poliambulatorio - Main clinic structure
model Poliambulatorio {
  id                   String        @id @default(uuid())
  tenantId             String
  nome                 String
  codice               String
  indirizzo            String?
  citta                String?
  cap                  String?
  provincia            String?
  telefono             String?
  email                String?
  pec                  String?
  partitaIva           String?
  codiceFiscale        String?
  codiceRegionale      String?
  direttoreSanitarioId String?
  isActive             Boolean       @default(true)
  createdAt            DateTime      @default(now()) @db.Timestamp(6)
  updatedAt            DateTime      @updatedAt @db.Timestamp(6)
  deletedAt            DateTime?

  // Relations
  tenant             Tenant          @relation(fields: [tenantId], references: [id])
  direttoreSanitario Person?         @relation("DirettoreSanitario", fields: [direttoreSanitarioId], references: [id], onDelete: SetNull)
  ambulatori         Ambulatorio[]
  numeriChiamata     NumeroChiamata[]

  @@unique([tenantId, codice])
  @@index([tenantId, deletedAt])
  @@index([codiceRegionale])
  @@index([direttoreSanitarioId])
  @@map("poliambulatori")
}

// Ambulatorio - Individual clinic room
model Ambulatorio {
  id                String                   @id @default(uuid())
  tenantId          String
  poliambulatorioId String
  nome              String
  codice            String
  specializzazione  String?
  piano             String?
  stanza            String?
  capienzaMax       Int                      @default(1)
  attrezzature      String?                  // JSON array of equipment
  isActive          Boolean                  @default(true)
  createdAt         DateTime                 @default(now()) @db.Timestamp(6)
  updatedAt         DateTime                 @updatedAt @db.Timestamp(6)
  deletedAt         DateTime?

  // Relations
  tenant          Tenant                   @relation(fields: [tenantId], references: [id])
  poliambulatorio Poliambulatorio          @relation(fields: [poliambulatorioId], references: [id], onDelete: Cascade)
  strumenti       StrumentoAmbulatorio[]
  appuntamenti    Appuntamento[]
  prestazioni     PrestazioneAmbulatorio[]
  orari           OrarioAmbulatorio[]

  @@unique([poliambulatorioId, codice])
  @@index([tenantId, deletedAt])
  @@index([poliambulatorioId])
  @@index([specializzazione])
  @@map("ambulatori")
}

// Prestazione - Medical service definition
model Prestazione {
  id                    String                   @id @default(uuid())
  tenantId              String
  codice                String
  codiceNazionale       String?                  // National nomenclator code
  nome                  String
  descrizione           String?
  tipo                  TipoPrestazione          @default(VISITA)
  durataPrevista        Int                      @default(30) // minutes
  richiedeReferto       Boolean                  @default(true)
  richiedeConsenso      Boolean                  @default(false)
  preparazioneRichiesta String?                  // Patient preparation instructions
  note                  String?
  isActive              Boolean                  @default(true)
  createdAt             DateTime                 @default(now()) @db.Timestamp(6)
  updatedAt             DateTime                 @updatedAt @db.Timestamp(6)
  deletedAt             DateTime?

  // Relations
  tenant              Tenant                   @relation(fields: [tenantId], references: [id])
  listinoPrezzi       ListinoPrezzo[]
  ambulatoriAbilitati PrestazioneAmbulatorio[]
  visite              Visita[]
  templateCampi       TemplateCampoVisita[]

  @@unique([tenantId, codice])
  @@index([tenantId, deletedAt])
  @@index([codiceNazionale])
  @@index([tipo])
  @@map("prestazioni")
}

// Junction table: Prestazione <-> Ambulatorio
model PrestazioneAmbulatorio {
  id            String      @id @default(uuid())
  prestazioneId String
  ambulatorioId String
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now()) @db.Timestamp(6)

  prestazione Prestazione @relation(fields: [prestazioneId], references: [id], onDelete: Cascade)
  ambulatorio Ambulatorio @relation(fields: [ambulatorioId], references: [id], onDelete: Cascade)

  @@unique([prestazioneId, ambulatorioId])
  @@index([prestazioneId])
  @@index([ambulatorioId])
  @@map("prestazione_ambulatorio")
}

// Strumento - Medical equipment
model Strumento {
  id                   String                 @id @default(uuid())
  tenantId             String
  codice               String
  nome                 String
  descrizione          String?
  marca                String?
  modello              String?
  numeroSerie          String?
  dataAcquisto         DateTime?              @db.Date
  dataScadenzaGaranzia DateTime?              @db.Date
  dataUltimaManutenz   DateTime?              @db.Date
  dataProssimaManutenz DateTime?              @db.Date
  stato                StatoStrumento         @default(DISPONIBILE)
  note                 String?
  isActive             Boolean                @default(true)
  createdAt            DateTime               @default(now()) @db.Timestamp(6)
  updatedAt            DateTime               @updatedAt @db.Timestamp(6)
  deletedAt            DateTime?

  // Relations
  tenant              Tenant                  @relation(fields: [tenantId], references: [id])
  ambulatoriAssegnati StrumentoAmbulatorio[]
  manutenzioni        ManutenzioneStrumento[]

  @@unique([tenantId, codice])
  @@index([tenantId, deletedAt])
  @@index([stato])
  @@index([dataProssimaManutenz])
  @@map("strumenti")
}

// Junction table: Strumento <-> Ambulatorio
model StrumentoAmbulatorio {
  id                   String      @id @default(uuid())
  strumentoId          String
  ambulatorioId        String
  dataAssegnazione     DateTime    @default(now()) @db.Date
  dataFineAssegnazione DateTime?   @db.Date
  isActive             Boolean     @default(true)

  strumento   Strumento   @relation(fields: [strumentoId], references: [id], onDelete: Cascade)
  ambulatorio Ambulatorio @relation(fields: [ambulatorioId], references: [id], onDelete: Cascade)

  @@unique([strumentoId, ambulatorioId, dataAssegnazione])
  @@index([strumentoId])
  @@index([ambulatorioId])
  @@map("strumento_ambulatorio")
}

// ListinoPrezzo - Price list for services
model ListinoPrezzo {
  id                String      @id @default(uuid())
  tenantId          String
  prestazioneId     String
  tipo              TipoListino @default(PRIVATO)
  prezzo            Decimal     @db.Decimal(10, 2)
  prezzoMinimo      Decimal?    @db.Decimal(10, 2)
  prezzoMassimo     Decimal?    @db.Decimal(10, 2)
  codiceConvenzione String?
  nomeConvenzione   String?
  validoDa          DateTime    @default(now()) @db.Date
  validoA           DateTime?   @db.Date
  note              String?
  isActive          Boolean     @default(true)
  createdAt         DateTime    @default(now()) @db.Timestamp(6)
  updatedAt         DateTime    @updatedAt @db.Timestamp(6)
  deletedAt         DateTime?

  // Relations
  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  prestazione Prestazione        @relation(fields: [prestazioneId], references: [id], onDelete: Cascade)
  convenzioni ConvenzioneListino[]

  @@unique([tenantId, prestazioneId, tipo, codiceConvenzione, validoDa])
  @@index([tenantId, deletedAt])
  @@index([prestazioneId])
  @@index([tipo])
  @@index([validoDa, validoA])
  @@map("listino_prezzi")
}

// Appuntamento - Appointment
model Appuntamento {
  id                   String            @id @default(uuid())
  tenantId             String
  numero               String            // Progressive number per day
  pazienteId           String
  medicoId             String
  ambulatorioId        String
  prestazioneId        String?
  dataOra              DateTime          @db.Timestamp(6)
  durataPrevista       Int               @default(30) // minutes
  stato                StatoAppuntamento @default(PRENOTATO)
  note                 String?
  noteInterne          String?           // Staff only notes
  promemoria           Boolean           @default(true)
  promemoriaInviato    Boolean           @default(false)
  dataConferma         DateTime?         @db.Timestamp(6)
  dataAnnullamento     DateTime?         @db.Timestamp(6)
  motivoAnnullamento   String?
  numeroCoda           Int?              // Queue number for waiting room
  oraArrivo            DateTime?         @db.Timestamp(6)
  oraInizio            DateTime?         @db.Timestamp(6)
  oraFine              DateTime?         @db.Timestamp(6)
  isRecurring          Boolean           @default(false)
  recurringPattern     String?           // JSON with recurrence rules
  parentAppuntamentoId String?
  createdBy            String?
  createdAt            DateTime          @default(now()) @db.Timestamp(6)
  updatedAt            DateTime          @updatedAt @db.Timestamp(6)
  deletedAt            DateTime?

  // Relations
  tenant             Tenant         @relation(fields: [tenantId], references: [id])
  paziente           Person         @relation("AppuntamentiPaziente", fields: [pazienteId], references: [id], onDelete: Restrict)
  medico             Person         @relation("AppuntamentiMedico", fields: [medicoId], references: [id], onDelete: Restrict)
  ambulatorio        Ambulatorio    @relation(fields: [ambulatorioId], references: [id], onDelete: Restrict)
  parentAppuntamento Appuntamento?  @relation("RecurringAppuntamenti", fields: [parentAppuntamentoId], references: [id], onDelete: SetNull)
  childAppuntamenti  Appuntamento[] @relation("RecurringAppuntamenti")
  visite             Visita[]

  @@unique([tenantId, numero, dataOra])
  @@index([tenantId, deletedAt])
  @@index([pazienteId])
  @@index([medicoId])
  @@index([ambulatorioId])
  @@index([dataOra])
  @@index([stato])
  @@index([tenantId, dataOra, stato])
  @@index([medicoId, dataOra])
  @@index([ambulatorioId, dataOra])
  @@map("appuntamenti")
}

// Visita - Medical visit
model Visita {
  id                  String      @id @default(uuid())
  tenantId            String
  appuntamentoId      String?
  pazienteId          String
  medicoId            String
  prestazioneId       String
  dataOra             DateTime    @db.Timestamp(6)
  stato               StatoVisita @default(INIZIATA)
  // Clinical data
  anamnesi            String?     // Patient history
  esamObiettivo       String?     // Physical examination
  diagnosi            String?
  diagnosiIcd10       String?     // ICD-10 code
  terapia             String?
  prescrizioni        String?     // JSON array of prescriptions
  noteClinic          String?     // Clinical notes (encrypted)
  // Follow-up
  followUpRichiesto   Boolean     @default(false)
  followUpData        DateTime?   @db.Date
  followUpNote        String?
  // Digital signature
  firmaMedico         String?     // Digital signature reference
  dataFirma           DateTime?   @db.Timestamp(6)
  // Consents
  consensoInformato   Boolean     @default(false)
  consensoTrattamento Boolean     @default(false)
  createdBy           String?
  createdAt           DateTime    @default(now()) @db.Timestamp(6)
  updatedAt           DateTime    @updatedAt @db.Timestamp(6)
  deletedAt           DateTime?

  // Relations
  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  appuntamento Appuntamento?      @relation(fields: [appuntamentoId], references: [id], onDelete: SetNull)
  paziente     Person             @relation("VisitePaziente", fields: [pazienteId], references: [id], onDelete: Restrict)
  medico       Person             @relation("VisiteMedico", fields: [medicoId], references: [id], onDelete: Restrict)
  prestazione  Prestazione        @relation(fields: [prestazioneId], references: [id], onDelete: Restrict)
  referti      Referto[]
  allegati     AllegatoVisita[]
  valoriCampi  ValoreCampoVisita[]

  @@index([tenantId, deletedAt])
  @@index([pazienteId])
  @@index([medicoId])
  @@index([appuntamentoId])
  @@index([prestazioneId])
  @@index([dataOra])
  @@index([stato])
  @@index([tenantId, dataOra, stato])
  @@map("visite")
}

// Referto - Medical report
model Referto {
  id              String       @id @default(uuid())
  tenantId        String
  visitaId        String
  tipo            String       // Type of report (lab, imaging, etc.)
  codice          String       // Report code
  titolo          String
  contenuto       String?      // Report content (may be encrypted)
  conclusioni     String?      // Conclusions
  valoriRiferimento String?    // Reference values (JSON)
  stato           StatoReferto @default(BOZZA)
  dataEmissione   DateTime?    @db.Timestamp(6)
  // Digital signature
  firmaMedico     String?
  dataFirma       DateTime?    @db.Timestamp(6)
  firmaValidata   Boolean      @default(false)
  // Delivery
  consegnatoIl    DateTime?    @db.Timestamp(6)
  consegnatoA     String?      // Delivered to (patient name/email)
  metodiConsegna  String?      // Delivery method (email, portal, print)
  createdBy       String?
  createdAt       DateTime     @default(now()) @db.Timestamp(6)
  updatedAt       DateTime     @updatedAt @db.Timestamp(6)
  deletedAt       DateTime?

  // Relations
  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  visita   Visita            @relation(fields: [visitaId], references: [id], onDelete: Cascade)
  allegati AllegatoReferto[]
  versioni VersioneReferto[]

  @@unique([tenantId, codice])
  @@index([tenantId, deletedAt])
  @@index([visitaId])
  @@index([stato])
  @@index([dataEmissione])
  @@map("referti")
}

// Allegato Visita - Visit attachment
model AllegatoVisita {
  id           String   @id @default(uuid())
  visitaId     String
  tipo         String   // image, document, lab_result, etc.
  nome         String
  descrizione  String?
  filePath     String
  mimeType     String
  dimensione   Int      // bytes
  uploadatoBy  String?
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  deletedAt    DateTime?

  // Relations
  visita Visita @relation(fields: [visitaId], references: [id], onDelete: Cascade)

  @@index([visitaId])
  @@map("allegati_visita")
}

// Allegato Referto - Report attachment
model AllegatoReferto {
  id          String   @id @default(uuid())
  refertoId   String
  tipo        String   // pdf, image, dicom, etc.
  nome        String
  descrizione String?
  filePath    String
  mimeType    String
  dimensione  Int      // bytes
  uploadatoBy String?
  createdAt   DateTime @default(now()) @db.Timestamp(6)
  deletedAt   DateTime?

  // Relations
  referto Referto @relation(fields: [refertoId], references: [id], onDelete: Cascade)

  @@index([refertoId])
  @@map("allegati_referto")
}

// DisponibilitaMedico - Doctor availability for agenda
model DisponibilitaMedico {
  id             String    @id @default(uuid())
  tenantId       String
  medicoId       String
  ambulatorioId  String?   // If null, generic availability
  giornoSettimana Int      // 0=Sunday, 1=Monday, etc.
  oraInizio      String    // HH:MM format
  oraFine        String    // HH:MM format
  validoDa       DateTime  @default(now()) @db.Date
  validoA        DateTime? @db.Date
  note           String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now()) @db.Timestamp(6)
  updatedAt      DateTime  @updatedAt @db.Timestamp(6)
  deletedAt      DateTime?

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])
  medico Person @relation("DisponibilitaMedico", fields: [medicoId], references: [id], onDelete: Cascade)

  @@index([tenantId, deletedAt])
  @@index([medicoId])
  @@index([ambulatorioId])
  @@index([giornoSettimana])
  @@map("disponibilita_medico")
}

// FerieAssenza - Doctor vacation/absence
model FerieAssenza {
  id          String    @id @default(uuid())
  tenantId    String
  medicoId    String
  dataInizio  DateTime  @db.Date
  dataFine    DateTime  @db.Date
  motivo      String?   // vacation, sick, training, etc.
  note        String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamp(6)
  updatedAt   DateTime  @updatedAt @db.Timestamp(6)
  deletedAt   DateTime?

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])
  medico Person @relation("FerieAssenzaMedico", fields: [medicoId], references: [id], onDelete: Cascade)

  @@index([tenantId, deletedAt])
  @@index([medicoId])
  @@index([dataInizio, dataFine])
  @@map("ferie_assenze")
}

// FatturaSanitaria - Medical invoice
model FatturaSanitaria {
  id               String    @id @default(uuid())
  tenantId         String
  numero           String    // Invoice number
  dataEmissione    DateTime  @db.Date
  pazienteId       String
  visitaId         String?
  imponibile       Decimal   @db.Decimal(10, 2)
  aliquotaIva      Decimal   @default(0) @db.Decimal(5, 2)
  importoIva       Decimal   @default(0) @db.Decimal(10, 2)
  totale           Decimal   @db.Decimal(10, 2)
  metodoPagamento  String?   // cash, card, transfer
  dataPagamento    DateTime? @db.Date
  stato            String    @default("emessa") // emessa, pagata, annullata
  note             String?
  // Sistema TS (Tessera Sanitaria)
  inviatoTS        Boolean   @default(false)
  dataInvioTS      DateTime? @db.Timestamp(6)
  codiceDocumentoTS String?
  createdBy        String?
  createdAt        DateTime  @default(now()) @db.Timestamp(6)
  updatedAt        DateTime  @updatedAt @db.Timestamp(6)
  deletedAt        DateTime?

  // Relations
  tenant   Tenant @relation(fields: [tenantId], references: [id])
  paziente Person @relation("FattureSanitariePaziente", fields: [pazienteId], references: [id], onDelete: Restrict)

  @@unique([tenantId, numero])
  @@index([tenantId, deletedAt])
  @@index([pazienteId])
  @@index([dataEmissione])
  @@index([stato])
  @@map("fatture_sanitarie")
}

// ============================================
// MODELLI CLINICI AGGIUNTIVI - ElementMedica
// ============================================

// OrarioAmbulatorio - Operating hours for ambulatorio
model OrarioAmbulatorio {
  id              String    @id @default(uuid())
  tenantId        String
  ambulatorioId   String
  giornoSettimana Int       // 0=Sunday, 1=Monday, etc.
  oraInizio       String    // HH:MM format
  oraFine         String    // HH:MM format
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @db.Timestamp(6)
  deletedAt       DateTime?

  // Relations
  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  ambulatorio Ambulatorio @relation(fields: [ambulatorioId], references: [id], onDelete: Cascade)

  @@unique([ambulatorioId, giornoSettimana, oraInizio])
  @@index([tenantId, deletedAt])
  @@index([ambulatorioId])
  @@index([giornoSettimana])
  @@map("orari_ambulatorio")
}

// ManutenzioneStrumento - Equipment maintenance records
model ManutenzioneStrumento {
  id            String    @id @default(uuid())
  tenantId      String
  strumentoId   String
  tipo          String    // preventiva, correttiva, calibrazione
  dataEsecuzione DateTime @db.Date
  dataProssima  DateTime? @db.Date
  esecutore     String?   // Who performed maintenance
  costo         Decimal?  @db.Decimal(10, 2)
  note          String?
  esito         String?   // positivo, negativo, da_ripetere
  certificato   String?   // Certificate path if any
  createdBy     String?
  createdAt     DateTime  @default(now()) @db.Timestamp(6)
  updatedAt     DateTime  @updatedAt @db.Timestamp(6)
  deletedAt     DateTime?

  // Relations
  tenant    Tenant    @relation(fields: [tenantId], references: [id])
  strumento Strumento @relation(fields: [strumentoId], references: [id], onDelete: Cascade)

  @@index([tenantId, deletedAt])
  @@index([strumentoId])
  @@index([dataEsecuzione])
  @@index([dataProssima])
  @@map("manutenzioni_strumento")
}

// Convenzione - Insurance/health plan agreements
model Convenzione {
  id                String    @id @default(uuid())
  tenantId          String
  codice            String    // Convention code
  nome              String    // Insurance/plan name
  tipo              String    // assicurazione, mutua, asl, altro
  descrizione       String?
  contatto          String?   // Contact person
  telefono          String?
  email             String?
  indirizzo         String?
  validoDa          DateTime  @db.Date
  validoA           DateTime? @db.Date
  percentualeSconto Decimal?  @db.Decimal(5, 2) // Default discount %
  massimaleAnnuo    Decimal?  @db.Decimal(10, 2)
  documentoPath     String?   // Agreement document path
  note              String?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now()) @db.Timestamp(6)
  updatedAt         DateTime  @updatedAt @db.Timestamp(6)
  deletedAt         DateTime?

  // Relations
  tenant  Tenant             @relation(fields: [tenantId], references: [id])
  listini ConvenzioneListino[]

  @@unique([tenantId, codice])
  @@index([tenantId, deletedAt])
  @@index([tipo])
  @@index([validoDa, validoA])
  @@map("convenzioni")
}

// ConvenzioneListino - Links convention to price list
model ConvenzioneListino {
  id            String   @id @default(uuid())
  convenzioneId String
  listinoId     String   // References ListinoPrezzo.id
  createdAt     DateTime @default(now()) @db.Timestamp(6)

  // Relations
  convenzione Convenzione   @relation(fields: [convenzioneId], references: [id], onDelete: Cascade)
  listino     ListinoPrezzo @relation(fields: [listinoId], references: [id], onDelete: Cascade)

  @@unique([convenzioneId, listinoId])
  @@index([convenzioneId])
  @@index([listinoId])
  @@map("convenzione_listino")
}

// CodiceScontoClinico - Clinical discount codes (different from CodiceSconto for courses)
model CodiceScontoClinico {
  id                String    @id @default(uuid())
  tenantId          String
  codice            String    // Discount code
  descrizione       String?
  tipo              String    // percentuale, fisso
  valore            Decimal   @db.Decimal(10, 2) // Discount value
  validoDa          DateTime  @default(now()) @db.Date
  validoA           DateTime? @db.Date
  limiteUtilizzi    Int?      // Max uses
  utilizziAttuali   Int       @default(0)
  prestazioniIds    String?   // JSON array of prestazione IDs (if limited)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now()) @db.Timestamp(6)
  updatedAt         DateTime  @updatedAt @db.Timestamp(6)
  deletedAt         DateTime?

  // Relations
  tenant Tenant @relation("CodiciScontoClinici", fields: [tenantId], references: [id])

  @@unique([tenantId, codice])
  @@index([tenantId, deletedAt])
  @@index([codice])
  @@index([validoDa, validoA])
  @@map("codici_sconto_clinici")
}

// TipoCampoVisita - Types for dynamic form fields
enum TipoCampoVisita {
  TESTO
  TEXTAREA
  NUMERO
  DECIMALE
  DATA
  DATETIME
  BOOLEAN
  SELECT
  MULTISELECT
  FILE
  
  @@map("tipo_campo_visita")
}

// TemplateCampoVisita - Dynamic form fields template for visits
model TemplateCampoVisita {
  id            String          @id @default(uuid())
  tenantId      String
  prestazioneId String
  nome          String          // Field name (internal)
  etichetta     String          // Display label
  tipo          TipoCampoVisita @default(TESTO)
  obbligatorio  Boolean         @default(false)
  ordine        Int             @default(0) // Display order
  opzioni       String?         // JSON array for SELECT/MULTISELECT
  valoreDefault String?
  validazione   String?         // JSON validation rules
  placeholder   String?
  helpText      String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now()) @db.Timestamp(6)
  updatedAt     DateTime        @updatedAt @db.Timestamp(6)
  deletedAt     DateTime?

  // Relations
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  prestazione Prestazione   @relation(fields: [prestazioneId], references: [id], onDelete: Cascade)
  valori      ValoreCampoVisita[]

  @@unique([prestazioneId, nome])
  @@index([tenantId, deletedAt])
  @@index([prestazioneId])
  @@index([ordine])
  @@map("template_campi_visita")
}

// ValoreCampoVisita - Actual values for dynamic fields in a visit
model ValoreCampoVisita {
  id           String   @id @default(uuid())
  visitaId     String
  campoId      String   // References TemplateCampoVisita
  valore       String?  // Stored as string, converted by type
  valoreJson   String?  // For complex types (multiselect, file refs)
  createdAt    DateTime @default(now()) @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @db.Timestamp(6)

  // Relations
  visita Visita              @relation(fields: [visitaId], references: [id], onDelete: Cascade)
  campo  TemplateCampoVisita @relation(fields: [campoId], references: [id], onDelete: Cascade)

  @@unique([visitaId, campoId])
  @@index([visitaId])
  @@index([campoId])
  @@map("valori_campo_visita")
}

// VersioneReferto - Report versioning for event sourcing
model VersioneReferto {
  id           String   @id @default(uuid())
  refertoId    String
  versione     Int      // Version number (1, 2, 3...)
  contenuto    String?  // Content at this version
  conclusioni  String?
  motivoModifica String? // Reason for modification
  modificatoDa String   // Person ID who made the change
  createdAt    DateTime @default(now()) @db.Timestamp(6)

  // Relations
  referto Referto @relation(fields: [refertoId], references: [id], onDelete: Cascade)

  @@unique([refertoId, versione])
  @@index([refertoId])
  @@index([createdAt])
  @@map("versioni_referto")
}

// FirmaDigitale - Digital signature records
model FirmaDigitale {
  id              String   @id @default(uuid())
  tenantId        String
  refertoId       String?  // Can be linked to referto
  visitaId        String?  // Or to visita
  firmatarioId    String   // Person who signed
  tipoFirma       String   // semplice, avanzata, qualificata
  hashDocumento   String   // Document hash at signing time
  certificato     String?  // Certificate reference
  timestampFirma  DateTime @db.Timestamp(6)
  ipAddress       String?
  userAgent       String?
  validaFino      DateTime? @db.Timestamp(6)
  revocata        Boolean  @default(false)
  dataRevoca      DateTime? @db.Timestamp(6)
  motivoRevoca    String?
  createdAt       DateTime @default(now()) @db.Timestamp(6)

  // Relations
  tenant     Tenant @relation(fields: [tenantId], references: [id])
  firmatario Person @relation("FirmeDigitali", fields: [firmatarioId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([refertoId])
  @@index([visitaId])
  @@index([firmatarioId])
  @@index([timestampFirma])
  @@map("firme_digitali")
}

// SlotDisponibilita - Specific time slots for appointments
model SlotDisponibilita {
  id              String    @id @default(uuid())
  tenantId        String
  medicoId        String
  ambulatorioId   String?
  prestazioneId   String?   // If slot is for specific service
  data            DateTime  @db.Date
  oraInizio       String    // HH:MM
  oraFine         String    // HH:MM
  stato           String    @default("libero") // libero, prenotato, bloccato
  appuntamentoId  String?   // If booked
  note            String?
  createdAt       DateTime  @default(now()) @db.Timestamp(6)
  updatedAt       DateTime  @updatedAt @db.Timestamp(6)
  deletedAt       DateTime?

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])
  medico Person @relation("SlotsDisponibilita", fields: [medicoId], references: [id], onDelete: Cascade)

  @@unique([medicoId, data, oraInizio])
  @@index([tenantId, deletedAt])
  @@index([medicoId])
  @@index([ambulatorioId])
  @@index([data])
  @@index([stato])
  @@index([medicoId, data, stato])
  @@map("slots_disponibilita")
}

// NumeroChiamata - Queue number for waiting room
model NumeroChiamata {
  id             String    @id @default(uuid())
  tenantId       String
  poliambulatorioId String
  data           DateTime  @db.Date
  numero         Int       // Progressive number for the day
  appuntamentoId String?
  pazienteId     String?
  stato          String    @default("attesa") // attesa, chiamato, in_visita, completato, saltato
  oraRitiro      DateTime? @db.Timestamp(6)
  oraChiamata    DateTime? @db.Timestamp(6)
  ambulatorioId  String?   // Called to which ambulatorio
  note           String?
  createdAt      DateTime  @default(now()) @db.Timestamp(6)
  updatedAt      DateTime  @updatedAt @db.Timestamp(6)

  // Relations
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  poliambulatorio Poliambulatorio @relation(fields: [poliambulatorioId], references: [id], onDelete: Cascade)

  @@unique([poliambulatorioId, data, numero])
  @@index([tenantId])
  @@index([poliambulatorioId])
  @@index([data])
  @@index([stato])
  @@index([appuntamentoId])
  @@map("numeri_chiamata")
}

// TipoAzioneClinica - Types of clinical actions for audit
enum TipoAzioneClinica {
  VISUALIZZAZIONE
  CREAZIONE
  MODIFICA
  ELIMINAZIONE
  FIRMA
  STAMPA
  EXPORT
  ACCESSO_DATI_SENSIBILI
  
  @@map("tipo_azione_clinica")
}

// AuditLogClinico - Clinical-specific audit trail
model AuditLogClinico {
  id             String            @id @default(uuid())
  tenantId       String
  personId       String            // Who performed the action
  azione         TipoAzioneClinica
  entita         String            // Entity type (visita, referto, etc.)
  entitaId       String            // Entity ID
  pazienteId     String?           // If action involves a patient
  descrizione    String?
  datiPrecedenti String?           // JSON of previous state
  datiNuovi      String?           // JSON of new state
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime          @default(now()) @db.Timestamp(6)

  // Relations
  tenant  Tenant @relation(fields: [tenantId], references: [id])
  person  Person @relation("AuditLogsClinici", fields: [personId], references: [id], onDelete: Restrict)

  @@index([tenantId])
  @@index([personId])
  @@index([pazienteId])
  @@index([entita, entitaId])
  @@index([azione])
  @@index([createdAt])
  @@map("audit_log_clinico")
}
