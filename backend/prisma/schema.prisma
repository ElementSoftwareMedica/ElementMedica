model Permission {
  id          String       @id @default(uuid())
  name        String       @unique
  description String?
  resource    String
  action      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  scope       String?      @default("all")
  siteId      String?
  site        CompanySite? @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@index([resource, action])
  @@index([scope])
