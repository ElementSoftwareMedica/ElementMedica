// ============================================================================

enum PrioritaChiamata {
  NORMALE
  URGENTE
  PRIORITARIO
  EMERGENZA

  @@map("priorita_chiamata")
}

enum StatoChiamata {
  IN_ATTESA
  CHIAMATO
  IN_VISITA
  COMPLETATO
  NON_PRESENTATO
  RIMANDATO

  @@map("stato_chiamata")
}

model NumeroChiamata {
